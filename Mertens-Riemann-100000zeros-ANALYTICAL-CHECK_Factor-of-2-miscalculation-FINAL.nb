   RowBox[{
    RowBox[{"Print", "[", "\"\<Parsing amplitudes (alphas)...\>\"", "]"}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"alphas", "=", 
     RowBox[{"ImportHighPrec", "[", "\"\<high_prec_alpha.txt\>\"", "]"}]}], 
    ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<Parsing phases (psi)...\>\"", "]"}], ";"}], 
   "\n", 
   RowBox[{
    RowBox[{"psi", "=", 
     RowBox[{"ImportHighPrec", "[", "\"\<high_prec_arg.txt\>\"", "]"}]}], 
    ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"nMax", "=", 
     RowBox[{"Length", "[", "zeros", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"n", "=", "70"}], ";", 
    RowBox[{"(*", 
     RowBox[{
      RowBox[{"Standard", " ", "70"}], "-", 
      RowBox[{
      "dimension", " ", "matrix", " ", "from", " ", "the", " ", "paper"}]}], 
     "*)"}], 
    RowBox[{"Print", "[", 
     RowBox[{
     "\"\<Loaded \>\"", ",", "nMax", ",", 
      "\"\< total zeros. Selected subset size for LLL: \>\"", ",", "n"}], 
     "]"}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"order", "=", 
     RowBox[{"Ordering", "[", 
      RowBox[{"alphas", ",", 
       RowBox[{"-", "n"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"gammaSub", "=", 
     RowBox[{"zeros", "[", 
      RowBox[{"[", "order", "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"psiSub", "=", 
     RowBox[{"psi", "[", 
      RowBox[{"[", "order", "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"alphaSub", "=", 
     RowBox[{"alphas", "[", 
      RowBox[{"[", "order", "]"}], "]"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"2.", " ", "Build", " ", "High"}], "-", 
     RowBox[{"Precision", " ", "Lattice", " ", "Matrix"}]}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<\\n=== 2. RUNNING LATTICE BASIS REDUCTION ===\>\"", 
     "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"v", "=", "800"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"dim", "=", 
     RowBox[{"n", "+", "2"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"M", "=", 
     RowBox[{"ConstantArray", "[", 
      RowBox[{"0", ",", 
       RowBox[{"{", 
        RowBox[{"dim", ",", "dim"}], "}"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Do", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"M", "[", 
        RowBox[{"[", 
         RowBox[{"1", ",", "i"}], "]"}], "]"}], "=", 
       RowBox[{"Floor", "[", 
        RowBox[{
         RowBox[{"gammaSub", "[", 
          RowBox[{"[", "i", "]"}], "]"}], "*", 
         RowBox[{"2", "^", 
          RowBox[{"(", 
           RowBox[{"v", "-", "10"}], ")"}]}]}], "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", "1", ",", "n"}], "}"}]}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"M", "[", 
      RowBox[{"[", 
       RowBox[{"1", ",", 
        RowBox[{"n", "+", "1"}]}], "]"}], "]"}], "=", "0"}], ";", 
    RowBox[{
     RowBox[{"M", "[", 
      RowBox[{"[", 
       RowBox[{"1", ",", 
        RowBox[{"n", "+", "2"}]}], "]"}], "]"}], "=", "1"}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"Do", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"M", "[", 
        RowBox[{"[", 
         RowBox[{"2", ",", "i"}], "]"}], "]"}], "=", 
       RowBox[{"-", 
        RowBox[{"Floor", "[", 
         RowBox[{
          RowBox[{"psiSub", "[", 
           RowBox[{"[", "i", "]"}], "]"}], "*", 
          RowBox[{"2", "^", "v"}]}], "]"}]}]}], ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", "1", ",", "n"}], "}"}]}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"M", "[", 
      RowBox[{"[", 
       RowBox[{"2", ",", 
        RowBox[{"n", "+", "1"}]}], "]"}], "]"}], "=", 
     RowBox[{"Floor", "[", 
      RowBox[{
       RowBox[{"2", "^", "v"}], "*", 
       RowBox[{"n", "^", "4"}]}], "]"}]}], ";", 
    RowBox[{
     RowBox[{"M", "[", 
      RowBox[{"[", 
       RowBox[{"2", ",", 
        RowBox[{"n", "+", "2"}]}], "]"}], "]"}], "=", "0"}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"FIX", " ", "1"}], ":", 
     RowBox[{
      RowBox[{"Explicit", " ", "250"}], "-", 
      RowBox[{
      "digit", " ", "numerical", " ", "wrapping", " ", "on", " ", "Pi", " ", 
       "to", " ", "block", " ", "precision", " ", "decay", " ", "during", " ",
        "matrix", " ", "scaling"}]}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Do", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"M", "[", 
        RowBox[{"[", 
         RowBox[{
          RowBox[{"i", "+", "2"}], ",", "i"}], "]"}], "]"}], "=", 
       RowBox[{"Floor", "[", 
        RowBox[{"N", "[", 
         RowBox[{
          RowBox[{"2", "*", "Pi", "*", 
           RowBox[{"2", "^", "v"}]}], ",", "250"}], "]"}], "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", "1", ",", "n"}], "}"}]}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"reduced", "=", 
     RowBox[{"LatticeReduce", "[", "M", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<LatticeReduce complete.\>\"", "]"}], ";"}], 
   "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"3.", " ", "Extract", " ", "Target", " ", "Coordinate"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<\\n=== 3. EXTRACTING TARGET COORDINATE ===\>\"", "]"}],
     ";"}], "\n", 
   RowBox[{
    RowBox[{"candidates", "=", 
     RowBox[{"Select", "[", 
      RowBox[{"reduced", ",", 
       RowBox[{
        RowBox[{
         RowBox[{"Abs", "[", 
          RowBox[{"#", "[", 
           RowBox[{"[", 
            RowBox[{"n", "+", "2"}], "]"}], "]"}], "]"}], ">", "0"}], "&"}]}],
       "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"best", "=", 
     RowBox[{"First", "[", 
      RowBox[{"SortBy", "[", 
       RowBox[{"candidates", ",", 
        RowBox[{
         RowBox[{"-", 
          RowBox[{"Abs", "[", 
           RowBox[{"#", "[", 
            RowBox[{"[", 
             RowBox[{"n", "+", "2"}], "]"}], "]"}], "]"}]}], "&"}]}], "]"}], 
      "]"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"z", "=", 
     RowBox[{"best", "[", 
      RowBox[{"[", 
       RowBox[{"n", "+", "2"}], "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"y0", "=", 
     RowBox[{"SetPrecision", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Abs", "[", "z", "]"}], "/", "1024"}], ",", "250"}], "]"}]}], 
    ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Base target location y0: \>\"", ",", 
      RowBox[{"ScientificForm", "[", 
       RowBox[{"y0", ",", "10"}], "]"}]}], "]"}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"4.", " ", "Neighborhood", " ", "Grid", " ", "Search"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", 
     "\"\<\\n=== 4. EXECUTING LOCAL NEIGHBORHOOD GRID SWEEP ===\>\"", "]"}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", 
     "\"\<Pre-calculating vectorized Ingham kernel array to maximize \
execution speed...\>\"", "]"}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"T", "=", 
     RowBox[{"zeros", "[", 
      RowBox[{"[", "nMax", "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"FIX", " ", "2"}], ":", 
     RowBox[{"Pre", "-", 
      RowBox[{
      "computed", " ", "outside", " ", "the", " ", "loop", " ", "and", " ", 
       "secured", " ", "with", " ", "exact", " ", "integer", " ", "0", " ", 
       "boundary", " ", "fallback"}]}]}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"kKernel", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"Module", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"t", "=", 
           RowBox[{
            RowBox[{"Abs", "[", 
             RowBox[{"zeros", "[", 
              RowBox[{"[", "i", "]"}], "]"}], "]"}], "/", "T"}]}], "}"}], ",", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"t", "<", "1"}], ",", 
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{"1", "-", "t"}], ")"}], "*", 
             RowBox[{"Cos", "[", 
              RowBox[{"Pi", "*", "t"}], "]"}]}], "+", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"1", "/", "Pi"}], ")"}], "*", 
             RowBox[{"Sin", "[", 
              RowBox[{"Pi", "*", "t"}], "]"}]}]}], ",", "0"}], "]"}]}], "]"}],
        ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "1", ",", "nMax"}], "}"}]}], "]"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Step", " ", "size", " ", "is", " ", "held", " ", "as", " ", "an", " ", 
     "exact", " ", "rational", " ", "expression", " ", "to", " ", "prevent", 
     " ", "float", " ", "contamination"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"stepSize", "=", 
     RowBox[{"1", "/", "1000"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"samples", "=", "200"}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"gridPoints", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"y0", "+", 
        RowBox[{"k", "*", "stepSize"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"k", ",", 
         RowBox[{
          RowBox[{"-", "samples"}], "/", "2"}], ",", 
         RowBox[{"samples", "/", "2"}]}], "}"}]}], "]"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
     "Function", " ", "to", " ", "evaluate", " ", "hK", " ", "safely", " ", 
      "using", " ", "pre"}], "-", 
     RowBox[{"calculated", " ", "kernel", " ", "weights"}]}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"evaluateHK", "[", "yVal_", "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", "sumVal", "}"}], ",", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{"FIX", " ", "3"}], ":", 
         RowBox[{
         "Restored", " ", "the", " ", "true", " ", "analytic", " ", "leading",
           " ", "negative", " ", "sign", " ", "to", " ", "properly", " ", 
          "locate", " ", "valley", " ", "structures"}]}], "*)"}], 
       RowBox[{
        RowBox[{"sumVal", "=", 
         RowBox[{
          RowBox[{"-", "2"}], "*", 
          RowBox[{"Sum", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"kKernel", "[", 
              RowBox[{"[", "i", "]"}], "]"}], "*", 
             RowBox[{"alphas", "[", 
              RowBox[{"[", "i", "]"}], "]"}], "*", 
             RowBox[{"Cos", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"zeros", "[", 
                 RowBox[{"[", "i", "]"}], "]"}], "*", "yVal"}], "-", 
               RowBox[{"psi", "[", 
                RowBox[{"[", "i", "]"}], "]"}]}], "]"}]}], ",", 
            RowBox[{"{", 
             RowBox[{"i", ",", "1", ",", "nMax"}], "}"}]}], "]"}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"N", "[", 
         RowBox[{"sumVal", ",", "20"}], "]"}]}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", 
     "\"\<Sweeping local window around y0 to locate the true wave trough...\>\
\"", "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"results", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"y", ",", 
         RowBox[{"evaluateHK", "[", "y", "]"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"y", ",", "gridPoints"}], "}"}]}], "]"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"MODIFICATION", " ", "1"}], ":", 
     RowBox[{
     "Sort", " ", "ascending", " ", "to", " ", "isolate", " ", "the", " ", 
      "lowest", " ", 
      RowBox[{"(", 
       RowBox[{"most", " ", "negative"}], ")"}], " ", "valley", " ", 
      "floor"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"sortedResults", "=", 
     RowBox[{"SortBy", "[", 
      RowBox[{"results", ",", 
       RowBox[{
        RowBox[{"#", "[", 
         RowBox[{"[", "2", "]"}], "]"}], "&"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"bestMatch", "=", 
     RowBox[{"First", "[", "sortedResults", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"troughY", "=", 
     RowBox[{"bestMatch", "[", 
      RowBox[{"[", "1", "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"troughValue", "=", 
     RowBox[{"bestMatch", "[", 
      RowBox[{"[", "2", "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<\\n=== FINAL VERIFICATION RESULTS ===\>\"", "]"}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Lowest localized trough found at y: \>\"", ",", 
      RowBox[{"ScientificForm", "[", 
       RowBox[{"N", "[", 
        RowBox[{"troughY", ",", "20"}], "]"}], "]"}]}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Maximum verified negative value of hK(y): \>\"", ",", 
      RowBox[{"InputForm", "[", "troughValue", "]"}]}], "]"}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"MODIFICATION", " ", "2"}], "&"}], " ", "3"}], ":", 
     RowBox[{
     "Evaluates", " ", "correctly", " ", "against", " ", "the", " ", 
      "negative", " ", "threshold", " ", "barrier"}]}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"N", "[", "troughValue", "]"}], "<", 
       RowBox[{"-", "1.0"}]}], ",", 
      RowBox[{"Print", "[", 
       RowBox[{
       "\"\<\[Checkmark] SUCCESS: The wave trough drops to \>\"", ",", 
        "troughValue", ",", 
        "\"\<, breaking the -1.0 barrier! The Mertens Conjecture is \
false.\>\""}], "]"}], ",", 
      RowBox[{
      "Print", "[", 
       "\"\<\:2717 Trough did not drop below -1.0. The neighborhood window \
needs to be widened or step size refined.\>\"", "]"}]}], "]"}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"FIX", " ", "4"}], ":", 
     RowBox[{
     "Wrap", " ", "results", " ", "array", " ", "in", " ", "standard", " ", 
      "N", " ", "execution", " ", "to", " ", "bypass", " ", "frontend", " ", 
      "UI", " ", "rendering", " ", "lags"}]}], "*)"}], "\[IndentingNewLine]", 
   
   RowBox[{"ListLinePlot", "[", 
    RowBox[{
     RowBox[{"N", "[", 
      RowBox[{"results", "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", "2"}], "]"}], "]"}], "]"}], ",", 
     RowBox[{
     "PlotLabel", "->", 
      "\"\<Local Wave Interference Near y0 (Trough Scan)\>\""}], ",", 
     RowBox[{"AxesLabel", "->", 
      RowBox[{"{", 
       RowBox[{"\"\<Sample Index\>\"", ",", "\"\<hK(y)\>\""}], "}"}]}], ",", 
     RowBox[{"GridLines", "->", "Automatic"}]}], "]"}]}]}]], "Input",
