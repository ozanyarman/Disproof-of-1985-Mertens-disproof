   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"4.", " ", "Neighborhood", " ", "Grid", " ", "Search"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", 
     "\"\<\\n=== 4. EXECUTING LOCAL NEIGHBORHOOD GRID SWEEP ===\>\"", "]"}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", 
     "\"\<Pre-calculating pure high-precision Ingham kernel array...\>\"", 
     "]"}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"T", "=", 
     RowBox[{"zeros", "[", 
      RowBox[{"[", "nMax", "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"FIX", " ", "2"}], ":", 
     RowBox[{
      RowBox[{
      "Swapped", " ", "0.0", " ", "float", " ", "with", " ", "an", " ", 
       "exact", " ", "0", " ", "to", " ", "defend", " ", "the", " ", "250"}], 
      "-", 
      RowBox[{
      "digit", " ", "environment", " ", "from", " ", "collapsing"}]}]}], 
    "*)"}], "\n", 
   RowBox[{
    RowBox[{"kKernel", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"Module", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"t", "=", 
           RowBox[{
            RowBox[{"Abs", "[", 
             RowBox[{"zeros", "[", 
              RowBox[{"[", "i", "]"}], "]"}], "]"}], "/", "T"}]}], "}"}], ",", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"t", "<", "1"}], ",", 
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{"1", "-", "t"}], ")"}], "*", 
             RowBox[{"Cos", "[", 
              RowBox[{"Pi", "*", "t"}], "]"}]}], "+", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"1", "/", "Pi"}], ")"}], "*", 
             RowBox[{"Sin", "[", 
              RowBox[{"Pi", "*", "t"}], "]"}]}]}], ",", "0"}], "]"}]}], "]"}],
        ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "1", ",", "nMax"}], "}"}]}], "]"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"FIX", " ", "3"}], ":", 
     RowBox[{
     "Replaced", " ", "the", " ", "SetPrecision", " ", "float", " ", 
      "wrapper", " ", "with", " ", "an", " ", "exact", " ", "rational", " ", 
      "fraction", " ", "step"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"stepSize", "=", 
     RowBox[{"2", "/", "100"}]}], ";", 
    RowBox[{"(*", 
     RowBox[{"Fixed", " ", "0.02", " ", "step", " ", "scale"}], "*)"}], 
    RowBox[{"samples", "=", "200"}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"gridPoints", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"y0", "+", 
        RowBox[{"k", "*", "stepSize"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"k", ",", 
         RowBox[{
          RowBox[{"-", "samples"}], "/", "2"}], ",", 
         RowBox[{"samples", "/", "2"}]}], "}"}]}], "]"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
     "Function", " ", "to", " ", "evaluate", " ", "hK", " ", "safely", " ", 
