   RowBox[{
    RowBox[{
    "Print", "[", "\"\<Pre-calculating Ingham kernel weights...\>\"", "]"}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"kKernel", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"1", "-", 
           RowBox[{
            RowBox[{"zeros", "[", 
             RowBox[{"[", "i", "]"}], "]"}], "/", "T"}]}], ")"}], "*", 
         RowBox[{"Cos", "[", 
          RowBox[{"Pi", "*", 
           RowBox[{
            RowBox[{"zeros", "[", 
             RowBox[{"[", "i", "]"}], "]"}], "/", "T"}]}], "]"}]}], "+", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"1", "/", "Pi"}], ")"}], "*", 
         RowBox[{"Sin", "[", 
          RowBox[{"Pi", "*", 
           RowBox[{
            RowBox[{"zeros", "[", 
             RowBox[{"[", "i", "]"}], "]"}], "/", "T"}]}], "]"}]}]}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "1", ",", "nMax"}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", 
     "\"\<\\n=== 2. LOCATING THE HISTORICAL 1985 ALIGNMENT REGION ===\>\"", 
     "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"dominantIndices", "=", 
     RowBox[{"Ordering", "[", 
      RowBox[{"alphas", ",", 
       RowBox[{"-", "5"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Dominant zero frequencies: \>\"", ",", 
      RowBox[{"N", "[", 
       RowBox[{
        RowBox[{"zeros", "[", 
         RowBox[{"[", "dominantIndices", "]"}], "]"}], ",", "4"}], "]"}]}], 
     "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<Scanning precision-safe phase intersections...\>\"", 
     "]"}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"FIX", " ", "1"}], ":", 
     RowBox[{
      RowBox[{
      "Replaced", " ", "machine", " ", "float", " ", "0.005", " ", "with", 
       " ", "exact", " ", "fraction", " ", 
       RowBox[{"1", "/", "200"}], " ", "to", " ", "safeguard", " ", "250"}], 
      "-", 
      RowBox[{"digit", " ", "tracking"}]}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"stepSize", "=", 
     RowBox[{"1", "/", "200"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"searchRange", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"100000", "+", 
        RowBox[{"k", "*", "stepSize"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"k", ",", "0", ",", "50000"}], "}"}]}], "]"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Track", " ", "the", " ", "minimum", " ", "value", " ", "safely", " ", 
     "in", " ", "the", " ", "negative", " ", "domain"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"maxVal", "=", "Infinity"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"bestY", "=", "0"}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"Do", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"y", "=", 
        RowBox[{"searchRange", "[", 
         RowBox[{"[", "k", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
        "Evaluating", " ", "localized", " ", "wave", " ", "crest", " ", 
         "using", " ", "the", " ", "true", " ", "analytic", " ", "explicit", 
         " ", "formula"}], "*)"}], 
       RowBox[{"currentVal", "=", 
        RowBox[{
         RowBox[{"-", "2"}], "*", 
         RowBox[{"Sum", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"kKernel", "[", 
             RowBox[{"[", "i", "]"}], "]"}], "*", 
            RowBox[{"alphas", "[", 
             RowBox[{"[", "i", "]"}], "]"}], "*", 
            RowBox[{"Cos", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"zeros", "[", 
                RowBox[{"[", "i", "]"}], "]"}], "*", "y"}], "-", 
              RowBox[{"psi", "[", 
               RowBox[{"[", "i", "]"}], "]"}]}], "]"}]}], ",", 
           RowBox[{"{", 
            RowBox[{"i", ",", "1", ",", "50"}], "}"}]}], "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"currentVal", "<", "maxVal"}], ",", 
         RowBox[{
          RowBox[{"maxVal", "=", "currentVal"}], ";", 
          RowBox[{"bestY", "=", "y"}], ";"}]}], "]"}], ";"}], ",", 
      RowBox[{"{", 
       RowBox[{"k", ",", "1", ",", 
        RowBox[{"Length", "[", "searchRange", "]"}]}], "}"}]}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<\\nBest baseline candidate isolated at y = \>\"", ",", 
      RowBox[{"N", "[", 
       RowBox[{"bestY", ",", "15"}], "]"}]}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Baseline valley floor value (first 50 zeros): \>\"", ",", 
      RowBox[{"N", "[", 
       RowBox[{"maxVal", ",", "10"}], "]"}]}], "]"}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"3.", " ", "High"}], "-", 
     RowBox[{
     "Precision", " ", "Valley", " ", "Descent", " ", "from", " ", "the", " ",
       "Baseline", " ", "Point"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", 
     "\"\<\\n=== 3. RUNNING EXACT SPECTRUM VALLEY-DESCENT ===\>\"", "]"}], 
    ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"FIX", " ", "2"}], ":", 
     RowBox[{
      RowBox[{"Maintained", " ", "complete", " ", "250"}], "-", 
      RowBox[{
      "digit", " ", "precision", " ", "tracking", " ", "to", " ", 
       "completely", " ", "prevent", " ", "high"}], "-", 
      RowBox[{"frequency", " ", "phase", " ", "drift"}]}]}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"currentY", "=", 
     RowBox[{"SetPrecision", "[", 
      RowBox[{"bestY", ",", "250"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   "\n", 
   RowBox[{
    RowBox[{"Do", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"val", "=", 
        RowBox[{
         RowBox[{"-", "2"}], "*", 
         RowBox[{"Sum", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"kKernel", "[", 
             RowBox[{"[", "i", "]"}], "]"}], "*", 
            RowBox[{"alphas", "[", 
             RowBox[{"[", "i", "]"}], "]"}], "*", 
            RowBox[{"Cos", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"zeros", "[", 
                RowBox[{"[", "i", "]"}], "]"}], "*", "currentY"}], "-", 
              RowBox[{"psi", "[", 
               RowBox[{"[", "i", "]"}], "]"}]}], "]"}]}], ",", 
           RowBox[{"{", 
            RowBox[{"i", ",", "1", ",", "nMax"}], "}"}]}], "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
        "Pure", " ", "analytic", " ", "derivative", " ", "chains", " ", 
         "mapped", " ", "perfectly", " ", "for", " ", "critical", " ", 
         "point", " ", "root", " ", "finding"}], "*)"}], 
       RowBox[{"deriv1", "=", 
        RowBox[{"2", "*", 
         RowBox[{"Sum", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"kKernel", "[", 
             RowBox[{"[", "i", "]"}], "]"}], "*", 
            RowBox[{"alphas", "[", 
             RowBox[{"[", "i", "]"}], "]"}], "*", 
            RowBox[{"zeros", "[", 
             RowBox[{"[", "i", "]"}], "]"}], "*", 
            RowBox[{"Sin", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"zeros", "[", 
                RowBox[{"[", "i", "]"}], "]"}], "*", "currentY"}], "-", 
              RowBox[{"psi", "[", 
               RowBox[{"[", "i", "]"}], "]"}]}], "]"}]}], ",", 
           RowBox[{"{", 
            RowBox[{"i", ",", "1", ",", "nMax"}], "}"}]}], "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"deriv2", "=", 
        RowBox[{"2", "*", 
         RowBox[{"Sum", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"kKernel", "[", 
             RowBox[{"[", "i", "]"}], "]"}], "*", 
            RowBox[{"alphas", "[", 
             RowBox[{"[", "i", "]"}], "]"}], "*", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"zeros", "[", 
               RowBox[{"[", "i", "]"}], "]"}], "^", "2"}], ")"}], "*", 
            RowBox[{"Cos", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"zeros", "[", 
                RowBox[{"[", "i", "]"}], "]"}], "*", "currentY"}], "-", 
              RowBox[{"psi", "[", 
               RowBox[{"[", "i", "]"}], "]"}]}], "]"}]}], ",", 
           RowBox[{"{", 
            RowBox[{"i", ",", "1", ",", "nMax"}], "}"}]}], "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"step", "=", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"Abs", "[", "deriv2", "]"}], ">", "0"}], ",", 
          RowBox[{"deriv1", "/", "deriv2"}], ",", "0"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{"FIX", " ", "3"}], ":", 
         RowBox[{
         "Replaced", " ", "machine", " ", "float", " ", "0.01", " ", 
          "threshold", " ", "with", " ", "exact", " ", "rational", " ", 
          RowBox[{"1", "/", "100"}]}]}], "*)"}], 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Abs", "[", "step", "]"}], ">", 
          RowBox[{"1", "/", "100"}]}], ",", 
         RowBox[{"step", "=", 
          RowBox[{
           RowBox[{"Sign", "[", "step", "]"}], "*", 
           RowBox[{"(", 
            RowBox[{"1", "/", "100"}], ")"}]}]}]}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{
          RowBox[{"FIX", " ", "4"}], ":", 
          RowBox[{
           RowBox[{"Restored", " ", "standard", " ", "subtraction", " ", 
            RowBox[{"(", "-", ")"}], " ", 
            RowBox[{"operator", ".", "Newton"}]}], "-", 
           RowBox[{
           "Raphson", " ", "critical", " ", "point", " ", "hunting", " ", 
            "always", " ", "subtracts", " ", "the", " ", 
            RowBox[{"step", ".", "Since"}], " ", "the", " ", "grid", " ", 
            "search", " ", "seeds", " ", "a", " ", "localized", " ", "trough",
             " ", "where", " ", "curvature", " ", "is", " ", "positive", " ", 
            
            RowBox[{"(", 
             RowBox[{"deriv2", ">", "0"}], ")"}]}]}]}], ",", 
         RowBox[{
         "subtraction", " ", "accurately", " ", "pulls", " ", "the", " ", 
          "coordinate", " ", "down", " ", "into", " ", "the", " ", "absolute",
           " ", "lowest", " ", "point", " ", "of", " ", "the", " ", "valley", 
          " ", "floor"}]}], "*)"}], 
       RowBox[{"currentY", "=", 
        RowBox[{"currentY", "-", "step"}]}], ";"}], ",", 
      RowBox[{"{", 
       RowBox[{"iter", ",", "1", ",", "30"}], "}"}]}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"finalPeak", "=", 
     RowBox[{
      RowBox[{"-", "2"}], "*", 
      RowBox[{"Sum", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"kKernel", "[", 
          RowBox[{"[", "i", "]"}], "]"}], "*", 
         RowBox[{"alphas", "[", 
          RowBox[{"[", "i", "]"}], "]"}], "*", 
         RowBox[{"Cos", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"zeros", "[", 
             RowBox[{"[", "i", "]"}], "]"}], "*", "currentY"}], "-", 
           RowBox[{"psi", "[", 
            RowBox[{"[", "i", "]"}], "]"}]}], "]"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", "1", ",", "nMax"}], "}"}]}], "]"}]}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<\\n=== FINAL VERIFICATION RESULTS ===\>\"", "]"}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Verified Trough Location y: \>\"", ",", 
      RowBox[{"N", "[", 
       RowBox[{"currentY", ",", "20"}], "]"}]}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Maximum verified negative value of hK(y): \>\"", ",", 
      RowBox[{"N", "[", 
       RowBox[{"finalPeak", ",", "10"}], "]"}]}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"N", "[", "finalPeak", "]"}], "<", 
       RowBox[{"-", "1.0"}]}], ",", 
      RowBox[{"Print", "[", 
       RowBox[{"\"\<\[Checkmark] SUCCESS: The wave trough drops to \>\"", ",", 
        RowBox[{"N", "[", 
         RowBox[{"finalPeak", ",", "6"}], "]"}], ",", 
        "\"\<, breaking the -1.0 barrier! The Mertens Conjecture is \
false.\>\""}], "]"}], ",", 
      RowBox[{
      "Print", "[", 
       "\"\<\:2717 Wave trough did not drop below -1.0. This configuration \
remains bounded above -1.0.\>\"", "]"}]}], "]"}], ";"}]}]}]], "Input",
