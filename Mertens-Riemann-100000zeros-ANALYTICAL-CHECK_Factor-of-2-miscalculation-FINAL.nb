   RowBox[{
    RowBox[{
    "Print", "[", "\"\<\\n=== 3. EXTRACTING TARGET COORDINATE ===\>\"", "]"}],
     ";"}], "\n", 
   RowBox[{
    RowBox[{"candidates", "=", 
     RowBox[{"Select", "[", 
      RowBox[{"reduced", ",", 
       RowBox[{
        RowBox[{
         RowBox[{"Abs", "[", 
          RowBox[{"#", "[", 
           RowBox[{"[", 
            RowBox[{"n", "+", "2"}], "]"}], "]"}], "]"}], ">", "0"}], "&"}]}],
       "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"best", "=", 
     RowBox[{"First", "[", 
      RowBox[{"SortBy", "[", 
       RowBox[{"candidates", ",", 
        RowBox[{
         RowBox[{"-", 
          RowBox[{"Abs", "[", 
           RowBox[{"#", "[", 
            RowBox[{"[", 
             RowBox[{"n", "+", "2"}], "]"}], "]"}], "]"}]}], "&"}]}], "]"}], 
      "]"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"z", "=", 
     RowBox[{"best", "[", 
      RowBox[{"[", 
       RowBox[{"n", "+", "2"}], "]"}], "]"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
     "Exact", " ", "Rational", " ", "Division", " ", "flawlessly", " ", 
      "preserves", " ", "the", " ", "250"}], "-", 
     RowBox[{"digit", " ", "tracking", " ", "space"}]}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"y0", "=", 
     RowBox[{"SetPrecision", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Abs", "[", "z", "]"}], "/", "1024"}], ",", "250"}], "]"}]}], 
