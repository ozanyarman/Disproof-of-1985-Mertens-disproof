Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"::", "Title", "::"}], "*)"}], 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"Pure", " ", "Phase"}], "-", 
      RowBox[{"Alignment", " ", 
       RowBox[{"Verification", ":", "Corrected"}]}]}], "&"}], " ", 
    "Calibrated"}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"ClearAll", "[", "\"\<Global`*\>\"", "]"}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
    "SetDirectory", "[", 
     "\"\</Users/ozanyarman/Documents/Wolfram Mathematica/\>\"", "]"}], ";"}],
    "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", 
     "\"\<=== 1. LOADING DATA WITH EXPLICIT PRECISION GUARD ===\>\"", "]"}], 
    ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"High", "-", 
     RowBox[{"precision", " ", "string"}], "-", 
     RowBox[{
     "safe", " ", "importer", " ", "to", " ", "handle", " ", "space"}], "-", 
     RowBox[{"separated", " ", "formatting"}]}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"ImportHighPrec", "[", "fileName_", "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"rawText", ",", "stringTokens"}], "}"}], ",", 
       RowBox[{
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"Not", "[", 
           RowBox[{"FileExistsQ", "[", "fileName", "]"}], "]"}], ",", 
          RowBox[{
           RowBox[{"Print", "[", 
            RowBox[{
            "\"\<ERROR: \>\"", ",", "fileName", ",", "\"\< not found!\>\""}], 
            "]"}], ";", 
           RowBox[{"Abort", "[", "]"}]}]}], "]"}], ";", "\[IndentingNewLine]", 
        RowBox[{"rawText", "=", 
         RowBox[{"Import", "[", 
          RowBox[{"fileName", ",", "\"\<String\>\""}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"stringTokens", "=", 
         RowBox[{"StringSplit", "[", "rawText", "]"}]}], ";", 
        RowBox[{"(*", 
         RowBox[{
          RowBox[{"Splits", " ", "cleanly", " ", "by", " ", "spaces"}], ",", 
          "tabs", ",", 
          RowBox[{"or", " ", "newlines"}]}], "*)"}], 
        RowBox[{"Map", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"ToExpression", "[", 
            RowBox[{"#", "<>", "\"\<`250\>\""}], "]"}], "&"}], ",", 
          "stringTokens"}], "]"}]}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   "\n", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<Parsing zeros...\>\"", "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"zeros", "=", 
     RowBox[{"ImportHighPrec", "[", "\"\<high_prec_zeros.txt\>\"", "]"}]}], 
    ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<Parsing amplitudes (alphas)...\>\"", "]"}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"alphas", "=", 
     RowBox[{"ImportHighPrec", "[", "\"\<high_prec_alpha.txt\>\"", "]"}]}], 
    ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<Parsing phases (psi)...\>\"", "]"}], ";"}], 
   "\n", 
   RowBox[{
    RowBox[{"psi", "=", 
     RowBox[{"ImportHighPrec", "[", "\"\<high_prec_arg.txt\>\"", "]"}]}], 
    ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"nMax", "=", 
     RowBox[{"Length", "[", "zeros", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"T", "=", 
     RowBox[{"zeros", "[", 
      RowBox[{"[", "nMax", "]"}], "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"FIX", " ", "1"}], ":", 
     RowBox[{
     "Strict", " ", "Piecewise", " ", "Ingham", " ", "Kernel", " ", "Domain", 
      " ", "Constraint", " ", "with", " ", "pure", " ", "exact", " ", 
      "precision"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<Pre-calculating Ingham kernel weights...\>\"", "]"}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"kKernel", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"Module", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"t", "=", 
           RowBox[{
            RowBox[{"Abs", "[", 
             RowBox[{"zeros", "[", 
              RowBox[{"[", "i", "]"}], "]"}], "]"}], "/", "T"}]}], "}"}], ",", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"t", "<", "1"}], ",", 
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{"1", "-", "t"}], ")"}], "*", 
             RowBox[{"Cos", "[", 
              RowBox[{"Pi", "*", "t"}], "]"}]}], "+", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"1", "/", "Pi"}], ")"}], "*", 
             RowBox[{"Sin", "[", 
              RowBox[{"Pi", "*", "t"}], "]"}]}]}], ",", "0"}], "]"}]}], "]"}],
        ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "1", ",", "nMax"}], "}"}]}], "]"}]}], ";", 
    RowBox[{"(*", 
     RowBox[{"Changed", " ", "0.0", " ", "to", " ", "0"}], "*)"}], 
    RowBox[{
    "Print", "[", "\"\<\\n=== 2. LOCALIZING PHASE INTERSECTION CREST ===\>\"",
      "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"dominantIndices", "=", 
     RowBox[{"Ordering", "[", 
      RowBox[{"alphas", ",", 
       RowBox[{"-", "5"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Dominant zero frequencies under test: \>\"", ",", 
      RowBox[{"N", "[", 
       RowBox[{
        RowBox[{"zeros", "[", 
         RowBox[{"[", "dominantIndices", "]"}], "]"}], ",", "4"}], "]"}]}], 
     "]"}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"FIX", " ", "2"}], ":", 
     RowBox[{
     "Converted", " ", "grid", " ", "boundaries", " ", "and", " ", "steps", 
      " ", "to", " ", "exact", " ", "rationals", " ", "to", " ", "block", " ",
       "precision", " ", "leaks"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"stepSize", "=", 
     RowBox[{"1", "/", "100"}]}], ";", 
    RowBox[{"(*", 
     RowBox[{
     "Exact", " ", "rational", " ", "instead", " ", "of", " ", "0.01"}], 
     "*)"}], 
    RowBox[{"samples", "=", "1000"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"searchRange", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"1000", "+", 
        RowBox[{"k", "*", "stepSize"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"k", ",", "0", ",", "samples"}], "}"}]}], "]"}]}], ";", 
    RowBox[{"(*", 
     RowBox[{"Changed", " ", "1000.0", " ", "to", " ", "1000"}], "*)"}], 
    RowBox[{"maxVal", "=", 
     RowBox[{"-", "Infinity"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"bestY", "=", "0"}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"Do", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"y", "=", 
        RowBox[{"searchRange", "[", 
         RowBox[{"[", "k", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{
         "Using", " ", "the", " ", "true", " ", "analytic", " ", "explicit", 
          " ", "formula", " ", "with", " ", "leading"}], "-", 
         RowBox[{"2", " ", "multiplier"}]}], "*)"}], 
       RowBox[{"currentVal", "=", 
        RowBox[{
         RowBox[{"-", "2"}], "*", 
         RowBox[{"Sum", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"kKernel", "[", 
             RowBox[{"[", "i", "]"}], "]"}], "*", 
            RowBox[{"alphas", "[", 
             RowBox[{"[", "i", "]"}], "]"}], "*", 
            RowBox[{"Cos", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"zeros", "[", 
                RowBox[{"[", "i", "]"}], "]"}], "*", "y"}], "-", 
              RowBox[{"psi", "[", 
               RowBox[{"[", "i", "]"}], "]"}]}], "]"}]}], ",", 
           RowBox[{"{", 
            RowBox[{"i", ",", "1", ",", "50"}], "}"}]}], "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"currentVal", ">", "maxVal"}], ",", 
         RowBox[{
          RowBox[{"maxVal", "=", "currentVal"}], ";", 
          RowBox[{"bestY", "=", "y"}], ";"}]}], "]"}], ";"}], ",", 
      RowBox[{"{", 
       RowBox[{"k", ",", "1", ",", 
        RowBox[{"Length", "[", "searchRange", "]"}]}], "}"}]}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Best local seed isolated at y = \>\"", ",", 
      RowBox[{"N", "[", 
       RowBox[{"bestY", ",", "15"}], "]"}]}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Grid seed baseline value (first 50 zeros): \>\"", ",", 
      RowBox[{"N", "[", 
       RowBox[{"maxVal", ",", "10"}], "]"}]}], "]"}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"3.", " ", "Corrected", " ", "High"}], "-", 
     RowBox[{"Precision", " ", "Hill", " ", "Climb"}]}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<\\n=== 3. RUNNING EXPLICIT SPECTRUM CLIMBER ===\>\"", 
     "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
     "Because", " ", "bestY", " ", "is", " ", "an", " ", "exact", " ", 
      "rational", " ", "expression"}], ",", 
     RowBox[{
     "SetPrecision", " ", "scales", " ", "flawlessly", " ", "to", " ", "250", 
      " ", "digits"}]}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"currentY", "=", 
     RowBox[{"SetPrecision", "[", 
      RowBox[{"bestY", ",", "250"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   "\n", 
   RowBox[{
    RowBox[{"Do", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"val", "=", 
        RowBox[{
         RowBox[{"-", "2"}], "*", 
         RowBox[{"Sum", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"kKernel", "[", 
             RowBox[{"[", "i", "]"}], "]"}], "*", 
            RowBox[{"alphas", "[", 
             RowBox[{"[", "i", "]"}], "]"}], "*", 
            RowBox[{"Cos", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"zeros", "[", 
                RowBox[{"[", "i", "]"}], "]"}], "*", "currentY"}], "-", 
              RowBox[{"psi", "[", 
               RowBox[{"[", "i", "]"}], "]"}]}], "]"}]}], ",", 
           RowBox[{"{", 
            RowBox[{"i", ",", "1", ",", "nMax"}], "}"}]}], "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
        "Pure", " ", "analytic", " ", "derivative", " ", "chains", " ", 
         "mapped", " ", "perfectly", " ", "to", " ", "force", " ", "ascent"}],
         "*)"}], 
       RowBox[{"deriv1", "=", 
        RowBox[{"2", "*", 
         RowBox[{"Sum", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"kKernel", "[", 
             RowBox[{"[", "i", "]"}], "]"}], "*", 
            RowBox[{"alphas", "[", 
             RowBox[{"[", "i", "]"}], "]"}], "*", 
            RowBox[{"zeros", "[", 
             RowBox[{"[", "i", "]"}], "]"}], "*", 
            RowBox[{"Sin", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"zeros", "[", 
                RowBox[{"[", "i", "]"}], "]"}], "*", "currentY"}], "-", 
              RowBox[{"psi", "[", 
               RowBox[{"[", "i", "]"}], "]"}]}], "]"}]}], ",", 
           RowBox[{"{", 
            RowBox[{"i", ",", "1", ",", "nMax"}], "}"}]}], "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"deriv2", "=", 
        RowBox[{"2", "*", 
         RowBox[{"Sum", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"kKernel", "[", 
             RowBox[{"[", "i", "]"}], "]"}], "*", 
            RowBox[{"alphas", "[", 
             RowBox[{"[", "i", "]"}], "]"}], "*", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"zeros", "[", 
               RowBox[{"[", "i", "]"}], "]"}], "^", "2"}], ")"}], "*", 
            RowBox[{"Cos", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"zeros", "[", 
                RowBox[{"[", "i", "]"}], "]"}], "*", "currentY"}], "-", 
              RowBox[{"psi", "[", 
               RowBox[{"[", "i", "]"}], "]"}]}], "]"}]}], ",", 
           RowBox[{"{", 
            RowBox[{"i", ",", "1", ",", "nMax"}], "}"}]}], "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{"Newton", "-", 
         RowBox[{
         "Raphson", " ", "step", " ", "maximized", " ", "for", " ", "finding",
           " ", "local", " ", "peaks", " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"f", "'"}], "/", 
            RowBox[{"f", "''"}]}], ")"}]}]}], "*)"}], 
       RowBox[{"step", "=", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"Abs", "[", "deriv2", "]"}], ">", "0"}], ",", 
          RowBox[{"deriv1", "/", "deriv2"}], ",", "0"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{"FIX", " ", "3"}], ":", 
         RowBox[{
          RowBox[{
          "Capped", " ", "using", " ", "exact", " ", "rational", " ", 
           RowBox[{"5", "/", "1000"}], " ", "to", " ", "completely", " ", 
           "block", " ", "machine"}], "-", 
          RowBox[{"float", " ", "contamination"}]}]}], "*)"}], 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Abs", "[", "step", "]"}], ">", 
          RowBox[{"5", "/", "1000"}]}], ",", 
         RowBox[{"step", "=", 
          RowBox[{
           RowBox[{"Sign", "[", "step", "]"}], "*", 
           RowBox[{"(", 
            RowBox[{"5", "/", "1000"}], ")"}]}]}]}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"currentY", "=", 
        RowBox[{"currentY", "-", "step"}]}], ";"}], ",", 
      RowBox[{"{", 
       RowBox[{"iter", ",", "1", ",", "40"}], "}"}]}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"finalPeak", "=", 
     RowBox[{
      RowBox[{"-", "2"}], "*", 
      RowBox[{"Sum", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"kKernel", "[", 
          RowBox[{"[", "i", "]"}], "]"}], "*", 
         RowBox[{"alphas", "[", 
          RowBox[{"[", "i", "]"}], "]"}], "*", 
         RowBox[{"Cos", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"zeros", "[", 
             RowBox[{"[", "i", "]"}], "]"}], "*", "currentY"}], "-", 
           RowBox[{"psi", "[", 
            RowBox[{"[", "i", "]"}], "]"}]}], "]"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", "1", ",", "nMax"}], "}"}]}], "]"}]}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<\\n=== FINAL VERIFICATION RESULTS ===\>\"", "]"}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Verified Peak Location y: \>\"", ",", 
      RowBox[{"N", "[", 
       RowBox[{"currentY", ",", "20"}], "]"}]}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Maximum verified value of hK(y): \>\"", ",", 
      RowBox[{"N", "[", 
       RowBox[{"finalPeak", ",", "10"}], "]"}]}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"N", "[", "finalPeak", "]"}], ">", "1.0"}], ",", 
      RowBox[{"Print", "[", 
       RowBox[{"\"\<\[Checkmark] SUCCESS: The wave peak reaches \>\"", ",", 
        RowBox[{"N", "[", 
         RowBox[{"finalPeak", ",", "6"}], "]"}], ",", 
        "\"\<, breaking the 1.0 barrier!\>\""}], "]"}], ",", 
      RowBox[{
      "Print", "[", 
       "\"\<\:2717 Wave peak did not clear 1.0. This configuration cannot \
align all elements.\>\"", "]"}]}], "]"}], ";"}]}]}]], "Input",
