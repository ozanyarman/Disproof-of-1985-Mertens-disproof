       "rendering", " ", "lags", " ", "with", " ", "high"}], "-", 
      RowBox[{"precision", " ", "floats"}]}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"ListLinePlot", "[", 
    RowBox[{
     RowBox[{"N", "[", 
      RowBox[{"results", "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", "2"}], "]"}], "]"}], "]"}], ",", 
