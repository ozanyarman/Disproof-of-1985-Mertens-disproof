Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"::", "Title", "::"}], "*)"}], 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"Pure", " ", "Phase"}], "-", 
      RowBox[{"Alignment", " ", 
       RowBox[{"Verification", ":", "Corrected"}]}]}], "&"}], " ", 
    RowBox[{"Calibrated", ":", 
     RowBox[{"Negative", " ", "Range"}]}]}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"ClearAll", "[", "\"\<Global`*\>\"", "]"}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
    "SetDirectory", "[", 
     "\"\</Users/ozanyarman/Documents/Wolfram Mathematica/\>\"", "]"}], ";"}],
    "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", 
     "\"\<=== 1. LOADING DATA WITH EXPLICIT PRECISION GUARD ===\>\"", "]"}], 
    ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"High", "-", 
     RowBox[{"precision", " ", "string"}], "-", 
     RowBox[{
     "safe", " ", "importer", " ", "to", " ", "handle", " ", "space"}], "-", 
     RowBox[{"separated", " ", "formatting"}]}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"ImportHighPrec", "[", "fileName_", "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"rawText", ",", "stringTokens"}], "}"}], ",", 
       RowBox[{
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"Not", "[", 
           RowBox[{"FileExistsQ", "[", "fileName", "]"}], "]"}], ",", 
          RowBox[{
           RowBox[{"Print", "[", 
            RowBox[{
            "\"\<ERROR: \>\"", ",", "fileName", ",", "\"\< not found!\>\""}], 
            "]"}], ";", 
           RowBox[{"Abort", "[", "]"}]}]}], "]"}], ";", "\[IndentingNewLine]", 
        RowBox[{"rawText", "=", 
         RowBox[{"Import", "[", 
          RowBox[{"fileName", ",", "\"\<String\>\""}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"stringTokens", "=", 
         RowBox[{"StringSplit", "[", "rawText", "]"}]}], ";", 
        RowBox[{"(*", 
         RowBox[{
          RowBox[{"Splits", " ", "cleanly", " ", "by", " ", "spaces"}], ",", 
          "tabs", ",", 
          RowBox[{"or", " ", "newlines"}]}], "*)"}], 
        RowBox[{"Map", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"ToExpression", "[", 
            RowBox[{"#", "<>", "\"\<`250\>\""}], "]"}], "&"}], ",", 
          "stringTokens"}], "]"}]}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   "\n", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<Parsing zeros...\>\"", "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"zeros", "=", 
     RowBox[{"ImportHighPrec", "[", "\"\<high_prec_zeros.txt\>\"", "]"}]}], 
    ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<Parsing amplitudes (alphas)...\>\"", "]"}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"alphas", "=", 
     RowBox[{"ImportHighPrec", "[", "\"\<high_prec_alpha.txt\>\"", "]"}]}], 
    ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<Parsing phases (psi)...\>\"", "]"}], ";"}], 
   "\n", 
   RowBox[{
    RowBox[{"psi", "=", 
     RowBox[{"ImportHighPrec", "[", "\"\<high_prec_arg.txt\>\"", "]"}]}], 
    ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"nMax", "=", 
     RowBox[{"Length", "[", "zeros", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"T", "=", 
     RowBox[{"zeros", "[", 
      RowBox[{"[", "nMax", "]"}], "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"FIX", " ", "1"}], ":", 
     RowBox[{
     "Piecewise", " ", "Ingham", " ", "Kernel", " ", "Domain", " ", 
      "Constraint", " ", "with", " ", "integer", " ", "zero", " ", 
      "guard"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<Pre-calculating Ingham kernel weights...\>\"", "]"}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"kKernel", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"Module", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"t", "=", 
           RowBox[{
            RowBox[{"Abs", "[", 
             RowBox[{"zeros", "[", 
              RowBox[{"[", "i", "]"}], "]"}], "]"}], "/", "T"}]}], "}"}], ",", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"t", "<", "1"}], ",", 
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{"1", "-", "t"}], ")"}], "*", 
             RowBox[{"Cos", "[", 
              RowBox[{"Pi", "*", "t"}], "]"}]}], "+", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"1", "/", "Pi"}], ")"}], "*", 
             RowBox[{"Sin", "[", 
              RowBox[{"Pi", "*", "t"}], "]"}]}]}], ",", "0"}], "]"}]}], "]"}],
        ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "1", ",", "nMax"}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", 
     "\"\<\\n=== 2. LOCALIZING PHASE INTERSECTION TROUGH ===\>\"", "]"}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"dominantIndices", "=", 
     RowBox[{"Ordering", "[", 
      RowBox[{"alphas", ",", 
       RowBox[{"-", "5"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Dominant zero frequencies under test: \>\"", ",", 
      RowBox[{"N", "[", 
       RowBox[{
        RowBox[{"zeros", "[", 
         RowBox[{"[", "dominantIndices", "]"}], "]"}], ",", "4"}], "]"}]}], 
     "]"}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"FIX", " ", "2"}], ":", 
     RowBox[{
     "Swapped", " ", "machine", " ", "floats", " ", "for", " ", "exact", " ", 
      "rationals", " ", "and", " ", "integers"}]}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"stepSize", "=", 
     RowBox[{"1", "/", "100"}]}], ";", 
    RowBox[{"(*", 
     RowBox[{
     "Exact", " ", "rational", " ", "instead", " ", "of", " ", "0.01"}], 
     "*)"}], 
    RowBox[{"samples", "=", "1000"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"searchRange", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"1000", "+", 
        RowBox[{"k", "*", "stepSize"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"k", ",", "0", ",", "samples"}], "}"}]}], "]"}]}], ";", 
    RowBox[{"(*", 
     RowBox[{
     "Integer", " ", "1000", " ", "instead", " ", "of", " ", "1000.0"}], 
     "*)"}], 
    RowBox[{"(*", 
     RowBox[{
     "Track", " ", "the", " ", "minimum", " ", "value", " ", "safely", " ", 
      "in", " ", "the", " ", "negative", " ", "domain"}], "*)"}], 
    RowBox[{"maxVal", "=", "Infinity"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"bestY", "=", "0"}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"Do", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"y", "=", 
        RowBox[{"searchRange", "[", 
         RowBox[{"[", "k", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"currentVal", "=", 
        RowBox[{
         RowBox[{"-", "2"}], "*", 
         RowBox[{"Sum", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"kKernel", "[", 
             RowBox[{"[", "i", "]"}], "]"}], "*", 
            RowBox[{"alphas", "[", 
             RowBox[{"[", "i", "]"}], "]"}], "*", 
            RowBox[{"Cos", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"zeros", "[", 
                RowBox[{"[", "i", "]"}], "]"}], "*", "y"}], "-", 
              RowBox[{"psi", "[", 
               RowBox[{"[", "i", "]"}], "]"}]}], "]"}]}], ",", 
           RowBox[{"{", 
            RowBox[{"i", ",", "1", ",", "50"}], "}"}]}], "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"currentVal", "<", "maxVal"}], ",", 
         RowBox[{
          RowBox[{"maxVal", "=", "currentVal"}], ";", 
          RowBox[{"bestY", "=", "y"}], ";"}]}], "]"}], ";"}], ",", 
      RowBox[{"{", 
       RowBox[{"k", ",", "1", ",", 
        RowBox[{"Length", "[", "searchRange", "]"}]}], "}"}]}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Best local valley seed isolated at y = \>\"", ",", 
      RowBox[{"N", "[", 
       RowBox[{"bestY", ",", "15"}], "]"}]}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Grid seed baseline value (first 50 zeros): \>\"", ",", 
      RowBox[{"N", "[", 
       RowBox[{"maxVal", ",", "10"}], "]"}]}], "]"}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"3.", " ", "High"}], "-", 
     RowBox[{"Precision", " ", "Valley", " ", "Descent"}]}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", 
     "\"\<\\n=== 3. RUNNING EXPLICIT SPECTRUM VALLEY-DESCENT ===\>\"", "]"}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"currentY", "=", 
     RowBox[{"SetPrecision", "[", 
      RowBox[{"bestY", ",", "250"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   "\n", 
   RowBox[{
    RowBox[{"Do", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"val", "=", 
        RowBox[{
         RowBox[{"-", "2"}], "*", 
         RowBox[{"Sum", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"kKernel", "[", 
             RowBox[{"[", "i", "]"}], "]"}], "*", 
            RowBox[{"alphas", "[", 
             RowBox[{"[", "i", "]"}], "]"}], "*", 
            RowBox[{"Cos", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"zeros", "[", 
                RowBox[{"[", "i", "]"}], "]"}], "*", "currentY"}], "-", 
              RowBox[{"psi", "[", 
               RowBox[{"[", "i", "]"}], "]"}]}], "]"}]}], ",", 
           RowBox[{"{", 
            RowBox[{"i", ",", "1", ",", "nMax"}], "}"}]}], "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"deriv1", "=", 
        RowBox[{"2", "*", 
         RowBox[{"Sum", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"kKernel", "[", 
             RowBox[{"[", "i", "]"}], "]"}], "*", 
            RowBox[{"alphas", "[", 
             RowBox[{"[", "i", "]"}], "]"}], "*", 
            RowBox[{"zeros", "[", 
             RowBox[{"[", "i", "]"}], "]"}], "*", 
            RowBox[{"Sin", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"zeros", "[", 
                RowBox[{"[", "i", "]"}], "]"}], "*", "currentY"}], "-", 
              RowBox[{"psi", "[", 
               RowBox[{"[", "i", "]"}], "]"}]}], "]"}]}], ",", 
           RowBox[{"{", 
            RowBox[{"i", ",", "1", ",", "nMax"}], "}"}]}], "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"deriv2", "=", 
        RowBox[{"2", "*", 
         RowBox[{"Sum", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"kKernel", "[", 
             RowBox[{"[", "i", "]"}], "]"}], "*", 
            RowBox[{"alphas", "[", 
             RowBox[{"[", "i", "]"}], "]"}], "*", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"zeros", "[", 
               RowBox[{"[", "i", "]"}], "]"}], "^", "2"}], ")"}], "*", 
            RowBox[{"Cos", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"zeros", "[", 
                RowBox[{"[", "i", "]"}], "]"}], "*", "currentY"}], "-", 
              RowBox[{"psi", "[", 
               RowBox[{"[", "i", "]"}], "]"}]}], "]"}]}], ",", 
           RowBox[{"{", 
            RowBox[{"i", ",", "1", ",", "nMax"}], "}"}]}], "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"step", "=", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"Abs", "[", "deriv2", "]"}], ">", "0"}], ",", 
          RowBox[{"deriv1", "/", "deriv2"}], ",", "0"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{"FIX", " ", "3"}], ":", 
         RowBox[{
         "Replaced", " ", "float", " ", "boundary", " ", "0.005", " ", "with",
           " ", "exact", " ", "fraction", " ", 
          RowBox[{"5", "/", "1000"}]}]}], "*)"}], 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Abs", "[", "step", "]"}], ">", 
          RowBox[{"5", "/", "1000"}]}], ",", 
         RowBox[{"step", "=", 
          RowBox[{
           RowBox[{"Sign", "[", "step", "]"}], "*", 
           RowBox[{"(", 
            RowBox[{"5", "/", "1000"}], ")"}]}]}]}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{
          RowBox[{"FIX", " ", "4"}], ":", 
          RowBox[{
           RowBox[{"Restored", " ", "standard", " ", "subtraction", " ", 
            RowBox[{"(", "-", ")"}], " ", 
            RowBox[{"operator", ".", "Newton"}]}], "-", 
           RowBox[{
           "Raphson", " ", "optimization", " ", "to", " ", "find", " ", 
            "roots", " ", "of", " ", "a", " ", "derivative", " ", "always", 
            " ", "subtracts", " ", "the", " ", 
            RowBox[{"step", ".", "Because"}], " ", "the", " ", "local", " ", 
            "seed", " ", "is", " ", "sitting", " ", "in", " ", "a", " ", 
            "convex", " ", "trough", " ", "basin"}]}]}], ",", 
         RowBox[{"the", " ", "positive", " ", "curvature", " ", 
          RowBox[{"(", 
           RowBox[{"deriv2", ">", "0"}], ")"}], " ", "will", " ", "naturally",
           " ", "guide", " ", "the", " ", "subtraction", " ", "downward", " ",
           "toward", " ", "the", " ", "minimum", " ", 
          RowBox[{"peak", "."}]}]}], "*)"}], 
       RowBox[{"currentY", "=", 
        RowBox[{"currentY", "-", "step"}]}], ";"}], ",", 
      RowBox[{"{", 
       RowBox[{"iter", ",", "1", ",", "40"}], "}"}]}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"finalPeak", "=", 
     RowBox[{
      RowBox[{"-", "2"}], "*", 
      RowBox[{"Sum", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"kKernel", "[", 
          RowBox[{"[", "i", "]"}], "]"}], "*", 
         RowBox[{"alphas", "[", 
          RowBox[{"[", "i", "]"}], "]"}], "*", 
         RowBox[{"Cos", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"zeros", "[", 
             RowBox[{"[", "i", "]"}], "]"}], "*", "currentY"}], "-", 
           RowBox[{"psi", "[", 
            RowBox[{"[", "i", "]"}], "]"}]}], "]"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", "1", ",", "nMax"}], "}"}]}], "]"}]}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<\\n=== FINAL VERIFICATION RESULTS ===\>\"", "]"}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Verified Trough Location y: \>\"", ",", 
      RowBox[{"N", "[", 
       RowBox[{"currentY", ",", "20"}], "]"}]}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Maximum verified negative value of hK(y): \>\"", ",", 
      RowBox[{"N", "[", 
       RowBox[{"finalPeak", ",", "10"}], "]"}]}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"N", "[", "finalPeak", "]"}], "<", 
       RowBox[{"-", "1.0"}]}], ",", 
      RowBox[{"Print", "[", 
       RowBox[{"\"\<\[Checkmark] SUCCESS: The wave trough drops to \>\"", ",", 
        RowBox[{"N", "[", 
         RowBox[{"finalPeak", ",", "6"}], "]"}], ",", 
        "\"\<, breaking the -1.0 barrier!\>\""}], "]"}], ",", 
      RowBox[{
      "Print", "[", 
       "\"\<\:2717 Wave trough did not drop below -1.0. This configuration \
remains bounded above -1.0.\>\"", "]"}]}], "]"}], ";"}]}]}]], "Input",
