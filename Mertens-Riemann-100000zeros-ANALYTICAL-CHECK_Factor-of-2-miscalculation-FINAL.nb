        RowBox[{"sumVal", "=", 
         RowBox[{
          RowBox[{"-", "2"}], "*", 
          RowBox[{"Sum", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"kKernel", "[", 
              RowBox[{"[", "i", "]"}], "]"}], "*", 
             RowBox[{"alphas", "[", 
              RowBox[{"[", "i", "]"}], "]"}], "*", 
             RowBox[{"Cos", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"zeros", "[", 
                 RowBox[{"[", "i", "]"}], "]"}], "*", "yVal"}], "-", 
               RowBox[{"psi", "[", 
                RowBox[{"[", "i", "]"}], "]"}]}], "]"}]}], ",", 
            RowBox[{"{", 
             RowBox[{"i", ",", "1", ",", "nMax"}], "}"}]}], "]"}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"N", "[", 
         RowBox[{"sumVal", ",", "20"}], "]"}]}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", 
     "\"\<Sweeping local window around y0 to locate the true wave trough...\>\
\"", "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"results", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"y", ",", 
         RowBox[{"evaluateHK", "[", "y", "]"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"y", ",", "gridPoints"}], "}"}]}], "]"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"MODIFICATION", " ", "1"}], ":", 
     RowBox[{
     "Ascending", " ", "sort", " ", "isolated", " ", "perfectly", " ", "to", 
      " ", "capture", " ", "the", " ", "deepest", " ", "valley", " ", 
      "floor"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"sortedResults", "=", 
     RowBox[{"SortBy", "[", 
      RowBox[{"results", ",", 
       RowBox[{
        RowBox[{"#", "[", 
         RowBox[{"[", "2", "]"}], "]"}], "&"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"bestMatch", "=", 
     RowBox[{"First", "[", "sortedResults", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"troughY", "=", 
     RowBox[{"bestMatch", "[", 
      RowBox[{"[", "1", "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"troughValue", "=", 
     RowBox[{"bestMatch", "[", 
      RowBox[{"[", "2", "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<\\n=== FINAL VERIFICATION RESULTS ===\>\"", "]"}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Lowest localized trough found at y: \>\"", ",", 
      RowBox[{"ScientificForm", "[", 
       RowBox[{"N", "[", 
        RowBox[{"troughY", ",", "20"}], "]"}], "]"}]}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Maximum verified negative value of hK(y): \>\"", ",", 
      RowBox[{"InputForm", "[", "troughValue", "]"}]}], "]"}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"MODIFICATION", " ", "2"}], "&"}], " ", "3"}], ":", 
     RowBox[{
     "Evaluates", " ", "correctly", " ", "against", " ", "the", " ", "lower", 
      " ", "negative", " ", "boundary"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"N", "[", "troughValue", "]"}], "<", 
