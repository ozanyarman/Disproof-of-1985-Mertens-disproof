   RowBox[{
    RowBox[{"Do", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"M", "[", 
        RowBox[{"[", 
         RowBox[{"1", ",", "i"}], "]"}], "]"}], "=", 
       RowBox[{"Floor", "[", 
        RowBox[{
         RowBox[{"gammaSub", "[", 
          RowBox[{"[", "i", "]"}], "]"}], "*", 
         RowBox[{"2", "^", 
          RowBox[{"(", 
           RowBox[{"v", "-", "10"}], ")"}]}]}], "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", "1", ",", "n"}], "}"}]}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"M", "[", 
      RowBox[{"[", 
       RowBox[{"1", ",", 
        RowBox[{"n", "+", "1"}]}], "]"}], "]"}], "=", "0"}], ";", 
    RowBox[{
     RowBox[{"M", "[", 
      RowBox[{"[", 
       RowBox[{"1", ",", 
        RowBox[{"n", "+", "2"}]}], "]"}], "]"}], "=", "1"}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"Do", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"M", "[", 
        RowBox[{"[", 
         RowBox[{"2", ",", "i"}], "]"}], "]"}], "=", 
       RowBox[{"-", 
        RowBox[{"Floor", "[", 
         RowBox[{
          RowBox[{"psiSub", "[", 
           RowBox[{"[", "i", "]"}], "]"}], "*", 
          RowBox[{"2", "^", "v"}]}], "]"}]}]}], ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", "1", ",", "n"}], "}"}]}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"M", "[", 
      RowBox[{"[", 
       RowBox[{"2", ",", 
        RowBox[{"n", "+", "1"}]}], "]"}], "]"}], "=", 
     RowBox[{"Floor", "[", 
      RowBox[{
       RowBox[{"2", "^", "v"}], "*", 
       RowBox[{"n", "^", "4"}]}], "]"}]}], ";", 
    RowBox[{
     RowBox[{"M", "[", 
      RowBox[{"[", 
       RowBox[{"2", ",", 
        RowBox[{"n", "+", "2"}]}], "]"}], "]"}], "=", "0"}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"FIX", " ", "1"}], ":", 
     RowBox[{
      RowBox[{"Enforce", " ", "explicit", " ", "250"}], "-", 
      RowBox[{
      "digit", " ", "boundaries", " ", "on", " ", "Pi", " ", "to", " ", 
       "completely", " ", "secure", " ", "lattice", " ", "scaling", " ", 
       "bounds"}]}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Do", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"M", "[", 
        RowBox[{"[", 
         RowBox[{
          RowBox[{"i", "+", "2"}], ",", "i"}], "]"}], "]"}], "=", 
       RowBox[{"Floor", "[", 
        RowBox[{"N", "[", 
         RowBox[{
          RowBox[{"2", "*", "Pi", "*", 
           RowBox[{"2", "^", "v"}]}], ",", "250"}], "]"}], "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", "1", ",", "n"}], "}"}]}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"reduced", "=", 
     RowBox[{"LatticeReduce", "[", "M", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<LatticeReduce complete.\>\"", "]"}], ";"}], 
   "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "3.", " ", "Extract", " ", "Target", " ", "Coordinate", " ", "with", " ", 
