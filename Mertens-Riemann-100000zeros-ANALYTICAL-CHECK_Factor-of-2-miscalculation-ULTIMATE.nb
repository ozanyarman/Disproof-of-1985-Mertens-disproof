             ",", 
            RowBox[{
             RowBox[{"c1", "=", 
              RowBox[{"row", "[", 
               RowBox[{"[", 
                RowBox[{"n", "+", "2"}], "]"}], "]"}]}], ";", 
             "\[IndentingNewLine]", 
             RowBox[{"c2", "=", 
              RowBox[{"If", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{"Floor", "[", 
                  RowBox[{
                   RowBox[{"2", "^", "v"}], "*", 
