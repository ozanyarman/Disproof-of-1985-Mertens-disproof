     "multiply", " ", "tracking", " ", "vectors", " ", "to", " ", "maximize", 
      " ", "dot", " ", "product", " ", "execution", " ", "velocity"}]}], 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"preFactorCombined", "=", 
     RowBox[{"kKernelHigh", "*", "alphasHigh"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
     "Function", " ", "to", " ", "evaluate", " ", "hK", " ", "safely", " ", 
      "using", " ", "lightning"}], "-", 
     RowBox[{"fast", " ", "vector", " ", "dot", " ", "products"}]}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"evaluateHK", "[", "yVal_", "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"yHigh", ",", "sumVal"}], "}"}], ",", 
       RowBox[{
        RowBox[{"yHigh", "=", 
         RowBox[{"SetPrecision", "[", 
          RowBox[{"yVal", ",", "550"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{"PERFORMANCE", " ", 
          RowBox[{"UPGRADE", ":", 
           RowBox[{
           "Replaced", " ", "Total", " ", "multiplication", " ", "with", " ", 
            "direct", " ", "Dot", " ", "Product", " ", 
            RowBox[{"(", ".", ")"}]}]}]}], "*)"}], 
        RowBox[{"sumVal", "=", 
         RowBox[{
          RowBox[{"-", "2"}], "*", 
          RowBox[{"preFactorCombined", ".", 
           RowBox[{"Cos", "[", 
            RowBox[{
             RowBox[{"zerosHigh", "*", "yHigh"}], "-", "psiHigh"}], 
            "]"}]}]}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"N", "[", 
         RowBox[{"sumVal", ",", "20"}], "]"}]}]}], "]"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", 
     "\"\<Sweeping local window around y0 to locate the true wave trough...\>\
\"", "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"results", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"y", ",", 
         RowBox[{"evaluateHK", "[", "y", "]"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"y", ",", "gridPoints"}], "}"}]}], "]"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"MODIFICATION", " ", "1"}], ":", 
     RowBox[{
     "Sort", " ", "ascending", " ", "to", " ", "isolate", " ", "the", " ", 
      "lowest", " ", 
      RowBox[{"(", 
       RowBox[{"most", " ", "negative"}], ")"}], " ", "valley", " ", 
      "floor"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"sortedResults", "=", 
     RowBox[{"SortBy", "[", 
      RowBox[{"results", ",", 
       RowBox[{
        RowBox[{"#", "[", 
         RowBox[{"[", "2", "]"}], "]"}], "&"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"bestMatch", "=", 
     RowBox[{"First", "[", "sortedResults", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"troughY", "=", 
     RowBox[{"bestMatch", "[", 
      RowBox[{"[", "1", "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"troughValue", "=", 
     RowBox[{"bestMatch", "[", 
      RowBox[{"[", "2", "]"}], "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<\\n=== FINAL VERIFICATION RESULTS ===\>\"", "]"}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Lowest localized trough found at y: \>\"", ",", 
      RowBox[{"ScientificForm", "[", 
       RowBox[{"N", "[", 
        RowBox[{"troughY", ",", "20"}], "]"}], "]"}]}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Maximum verified negative value of hK(y): \>\"", ",", 
      RowBox[{"InputForm", "[", "troughValue", "]"}]}], "]"}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"MODIFICATION", " ", "2"}], "&"}], " ", "3"}], ":", 
     RowBox[{
     "Evaluates", " ", "correctly", " ", "against", " ", "the", " ", 
      "negative", " ", "threshold", " ", "barrier"}]}], "*)"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"N", "[", "troughValue", "]"}], "<", 
       RowBox[{"-", "1.0"}]}], ",", 
      RowBox[{"Print", "[", 
       RowBox[{
       "\"\<[checkmark] SUCCESS: The wave trough drops to \>\"", ",", 
        "troughValue", ",", 
        "\"\<, breaking the -1.0 barrier! The Mertens Conjecture is \
false.\>\""}], "]"}], ",", 
      RowBox[{
      "Print", "[", 
       "\"\<\:2717 Trough did not drop below -1.0. The neighborhood window \
needs to be widened or step size refined.\>\"", "]"}]}], "]"}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"FIX", " ", "4"}], ":", 
     RowBox[{
     "Wrap", " ", "results", " ", "array", " ", "in", " ", "standard", " ", 
      "N", " ", "execution", " ", "to", " ", "bypass", " ", "frontend", " ", 
      "UI", " ", "rendering", " ", "lags"}]}], "*)"}], "\[IndentingNewLine]", 
   
   RowBox[{"ListLinePlot", "[", 
    RowBox[{
     RowBox[{"N", "[", 
      RowBox[{"results", "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", "2"}], "]"}], "]"}], "]"}], ",", 
     RowBox[{
     "PlotLabel", "->", 
      "\"\<Local Wave Interference Near y0 (Trough Scan)\>\""}], ",", 
     RowBox[{"AxesLabel", "->", 
      RowBox[{"{", 
       RowBox[{"\"\<Sample Index\>\"", ",", "\"\<hK(y)\>\""}], "}"}]}], ",", 
     RowBox[{"GridLines", "->", "Automatic"}], ",", 
     RowBox[{"PlotRange", "->", "All"}]}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.9899304905284653`*^9, 3.989930492828574*^9}, 
