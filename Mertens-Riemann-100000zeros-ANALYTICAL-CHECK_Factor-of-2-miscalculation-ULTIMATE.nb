        ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "1", ",", "nMax"}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"FIX", " ", "3"}], ":", 
     RowBox[{
     "Replaced", " ", "the", " ", "SetPrecision", " ", "float", " ", "step", 
