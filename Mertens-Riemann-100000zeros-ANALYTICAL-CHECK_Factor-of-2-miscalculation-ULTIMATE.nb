     "\"\<\\n=== 3. EXTRACTING TARGET COORDINATE VIA COSINE TROUGH INSPECTION \
===\>\"", "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"validRows", "=", 
     RowBox[{"Select", "[", 
