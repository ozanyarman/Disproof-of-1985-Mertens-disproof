                RowBox[{
                 RowBox[{"row", "[", 
                  RowBox[{"[", 
                   RowBox[{"n", "+", "1"}], "]"}], "]"}], "/", 
                 RowBox[{"Floor", "[", 
                  RowBox[{
                   RowBox[{"2", "^", "v"}], "*", 
                   RowBox[{"n", "^", "4"}]}], "]"}]}], ",", "0"}], "]"}]}], 
             ";", "\[IndentingNewLine]", 
             RowBox[{"candidateY0", "=", 
              RowBox[{"N", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{"Abs", "[", "c1", "]"}], "/", "1024"}], ",", "550"}],
                "]"}]}], ";", "\[IndentingNewLine]", 
             RowBox[{"(*", 
              RowBox[{
              "Scan", " ", "local", " ", "coordinates", " ", "using", " ", 
               "rapid", " ", "dot", " ", "products", " ", "to", " ", "check", 
               " ", "for", " ", "constructive", " ", "negative", " ", 
               "interference"}], "*)"}], 
             RowBox[{"minLocalSum", "=", 
              RowBox[{"Min", "[", 
               RowBox[{"Table", "[", 
                RowBox[{
                 RowBox[{
                  RowBox[{"-", "2"}], "*", 
                  RowBox[{"preFact", ".", 
                   RowBox[{"Cos", "[", 
                    RowBox[{
                    RowBox[{"subZeros", "*", 
                    RowBox[{"(", 
                    RowBox[{"candidateY0", "+", 
                    RowBox[{"k", "*", 
                    RowBox[{"1", "/", "1000"}]}]}], ")"}]}], "-", "subPsi"}], 
                    "]"}]}]}], ",", 
                 RowBox[{"{", 
                  RowBox[{"k", ",", 
                   RowBox[{"-", "10"}], ",", "10"}], "}"}]}], "]"}], "]"}]}], 
             ";", "\[IndentingNewLine]", 
             RowBox[{"{", 
              RowBox[{"row", ",", "candidateY0", ",", "minLocalSum", ",", 
               RowBox[{"Abs", "[", "c2", "]"}]}], "}"}]}]}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"row", ",", "validRows"}], "}"}]}], "]"}]}], ";"}]}], 
