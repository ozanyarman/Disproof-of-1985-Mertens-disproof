   RowBox[{
    RowBox[{
    "Print", "[", 
     "\"\<\\n=== 4. EXECUTING LOCAL NEIGHBORHOOD GRID SWEEP ===\>\"", "]"}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", 
     "\"\<Pre-calculating vectorized Ingham kernel array to maximize \
execution speed...\>\"", "]"}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"T", "=", 
     RowBox[{"zeros", "[", 
      RowBox[{"[", "nMax", "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"kKernel", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"Module", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"t", "=", 
           RowBox[{
            RowBox[{"Abs", "[", 
             RowBox[{"zeros", "[", 
