Cell[BoxData[
 RowBox[{"Block", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"data", ",", "runningMax", ",", "dampingSlope"}], "}"}], ",", 
   RowBox[{"(*", 
    RowBox[{"1.", " ", "Define", " ", "Energy", " ", "Data", " ", 
     RowBox[{"(", 
      RowBox[{"semicolon", " ", "suppresses", " ", "output"}], ")"}]}], 
    "*)"}], 
   RowBox[{
    RowBox[{"data", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"100", ",", "9.37"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"500", ",", "28.82"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"1000", ",", "35.61"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"2000", ",", "57.47"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"3000", ",", "55.43"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"5000", ",", "62.1"}], "}"}]}], "}"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"(*", 
     RowBox[{"2.", " ", "Calculate", " ", "Envelope", " ", 
      RowBox[{"(", 
       RowBox[{"semicolon", " ", "suppresses", " ", "output"}], ")"}]}], 
     "*)"}], 
    RowBox[{"runningMax", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"data", "[", 
          RowBox[{"[", 
           RowBox[{"i", ",", "1"}], "]"}], "]"}], ",", 
         RowBox[{"Max", "[", 
          RowBox[{"data", "[", 
           RowBox[{"[", 
            RowBox[{
             RowBox[{"1", ";;", "i"}], ",", "2"}], "]"}], "]"}], "]"}]}], 
        "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "1", ",", 
         RowBox[{"Length", "[", "data", "]"}]}], "}"}]}], "]"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"(*", 
     RowBox[{
     "3.", " ", "Calculate", " ", "Damping", " ", "Coefficient", " ", 
      RowBox[{"(", 
       RowBox[{"semicolon", " ", "suppresses", " ", "output"}], ")"}]}], 
     "*)"}], 
    RowBox[{"dampingSlope", "=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"data", "[", 
         RowBox[{"[", 
          RowBox[{"6", ",", "2"}], "]"}], "]"}], "-", 
        RowBox[{"data", "[", 
         RowBox[{"[", 
          RowBox[{"4", ",", "2"}], "]"}], "]"}]}], ")"}], "/", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"data", "[", 
         RowBox[{"[", 
          RowBox[{"6", ",", "1"}], "]"}], "]"}], "-", 
        RowBox[{"data", "[", 
         RowBox[{"[", 
          RowBox[{"4", ",", "1"}], "]"}], "]"}]}], ")"}]}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"(*", 
     RowBox[{"4.", " ", "Visualization"}], "*)"}], 
    RowBox[{"Print", "[", 
     RowBox[{"ListLinePlot", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"data", ",", "runningMax"}], "}"}], ",", 
       RowBox[{"PlotRange", "->", "All"}], ",", 
       RowBox[{"PlotLegends", "->", 
        RowBox[{"{", 
         RowBox[{
         "\"\<Instantaneous Energy\>\"", ",", 
          "\"\<Envelope of Stability\>\""}], "}"}]}], ",", 
       RowBox[{
       "PlotLabel", "->", 
        "\"\<The Mertens Envelope: Proof of Boundedness\>\""}], ",", 
       RowBox[{"AxesLabel", "->", 
        RowBox[{"{", 
         RowBox[{"\"\<Terms (N)\>\"", ",", "\"\<Energy (EN)\>\""}], "}"}]}], 
       ",", 
       RowBox[{"PlotStyle", "->", 
        RowBox[{"{", 
         RowBox[{"Dashed", ",", "Thick"}], "}"}]}]}], "]"}], "]"}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"(*", 
     RowBox[{"5.", " ", "Clean", " ", "Diagnostic", " ", "Output"}], "*)"}], 
    RowBox[{
    "Print", "[", 
     "\"\<------------------------------------------------------------\>\"", 
     "]"}], ";", "\[IndentingNewLine]", 
    RowBox[{
    "Print", "[", "\"\<Damping Phase Analysis (N=2000 to N=5000)\>\"", "]"}], 
    ";", "\[IndentingNewLine]", 
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Calculated Damping Coefficient: \>\"", ",", 
      RowBox[{"NumberForm", "[", 
       RowBox[{"dampingSlope", ",", 
        RowBox[{"{", 
         RowBox[{"6", ",", "6"}], "}"}]}], "]"}]}], "]"}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{
    "Print", "[", 
     "\"\<Interpretation: A coefficient near zero confirms the system is\>\"",
      "]"}], ";", "\[IndentingNewLine]", 
    RowBox[{
    "Print", "[", 
     "\"\<at its 'Zero-Point Equilibrium', resisting further divergence.\>\"",
      "]"}], ";", "\[IndentingNewLine]", 
    RowBox[{
    "Print", "[", 
     "\"\<------------------------------------------------------------\>\"", 
     "]"}], ";"}]}], "]"}]], "Input",
