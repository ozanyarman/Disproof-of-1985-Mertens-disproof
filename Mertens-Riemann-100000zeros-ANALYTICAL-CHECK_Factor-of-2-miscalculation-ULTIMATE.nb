Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"::", "Title", "::"}], "*)"}], 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
     RowBox[{
     "Complete", " ", "1985", " ", "Mertens", " ", "Disproof", " ", 
      "Replication"}], "&"}], " ", "Grid", " ", "Search"}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"ClearAll", "[", "\"\<Global`*\>\"", "]"}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "1.", " ", "Configure", " ", "Directories", " ", "and", " ", "Load", " ", 
     "Data"}], "*)"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
    "SetDirectory", "[", 
     "\"\</Users/apple/Documents/Wolfram Mathematica/\>\"", "]"}], ";"}], 
   "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", 
     "\"\<=== 1. LOADING DATA WITH EXPLICIT PRECISION GUARD ===\>\"", "]"}], 
    ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"High", "-", 
     RowBox[{"precision", " ", "string"}], "-", 
     RowBox[{
     "safe", " ", "importer", " ", "to", " ", "handle", " ", "space"}], "-", 
     RowBox[{"separated", " ", "formatting"}]}], "*)"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"ImportHighPrec", "[", "fileName_", "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"rawText", ",", "stringTokens"}], "}"}], ",", 
       RowBox[{
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"Not", "[", 
           RowBox[{"FileExistsQ", "[", "fileName", "]"}], "]"}], ",", 
          RowBox[{
           RowBox[{"Print", "[", 
            RowBox[{
            "\"\<ERROR: \>\"", ",", "fileName", ",", "\"\< not found!\>\""}], 
            "]"}], ";", 
           RowBox[{"Abort", "[", "]"}]}]}], "]"}], ";", "\[IndentingNewLine]", 
        RowBox[{"rawText", "=", 
         RowBox[{"Import", "[", 
          RowBox[{"fileName", ",", "\"\<String\>\""}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"stringTokens", "=", 
         RowBox[{"StringSplit", "[", "rawText", "]"}]}], ";", 
        RowBox[{"(*", 
         RowBox[{
          RowBox[{"Splits", " ", "cleanly", " ", "by", " ", "spaces"}], ",", 
          "tabs", ",", 
          RowBox[{"or", " ", "newlines"}]}], "*)"}], 
        RowBox[{"Map", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"ToExpression", "[", 
            RowBox[{"#", "<>", "\"\<`250\>\""}], "]"}], "&"}], ",", 
          "stringTokens"}], "]"}]}]}], "]"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<Parsing zeros...\>\"", "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"zeros", "=", 
     RowBox[{"ImportHighPrec", "[", "\"\<high_prec_zeros.txt\>\"", "]"}]}], 
    ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<Parsing amplitudes (alphas)...\>\"", "]"}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"alphas", "=", 
     RowBox[{"ImportHighPrec", "[", "\"\<high_prec_alpha.txt\>\"", "]"}]}], 
    ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<Parsing phases (psi)...\>\"", "]"}], ";"}], 
   "\n", 
   RowBox[{
    RowBox[{"psi", "=", 
     RowBox[{"ImportHighPrec", "[", "\"\<high_prec_arg.txt\>\"", "]"}]}], 
    ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"nMax", "=", 
     RowBox[{"Length", "[", "zeros", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"n", "=", "70"}], ";", 
    RowBox[{"(*", 
     RowBox[{
      RowBox[{"Standard", " ", "70"}], "-", 
      RowBox[{
      "dimension", " ", "matrix", " ", "from", " ", "the", " ", "paper"}]}], 
     "*)"}], 
    RowBox[{"Print", "[", 
     RowBox[{
     "\"\<Loaded \>\"", ",", "nMax", ",", 
      "\"\< total zeros. Selected subset size for LLL: \>\"", ",", "n"}], 
     "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Isolate", " ", "sub"}], "-", 
     RowBox[{
     "vectors", " ", "based", " ", "on", " ", "the", " ", "dominant", " ", 
      "amplitudes"}]}], "*)"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"order", "=", 
     RowBox[{"Ordering", "[", 
      RowBox[{"alphas", ",", 
       RowBox[{"-", "n"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"gammaSub", "=", 
     RowBox[{"zeros", "[", 
      RowBox[{"[", "order", "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"psiSub", "=", 
     RowBox[{"psi", "[", 
      RowBox[{"[", "order", "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"alphaSub", "=", 
     RowBox[{"alphas", "[", 
      RowBox[{"[", "order", "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"2.", " ", "Build", " ", "High"}], "-", 
     RowBox[{"Precision", " ", "Lattice", " ", "Matrix"}]}], "*)"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<\\n=== 2. RUNNING LATTICE BASIS REDUCTION ===\>\"", 
     "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"v", "=", "800"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"dim", "=", 
     RowBox[{"n", "+", "2"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"M", "=", 
     RowBox[{"ConstantArray", "[", 
      RowBox[{"0", ",", 
       RowBox[{"{", 
        RowBox[{"dim", ",", "dim"}], "}"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Do", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"M", "[", 
        RowBox[{"[", 
         RowBox[{"1", ",", "i"}], "]"}], "]"}], "=", 
       RowBox[{"Floor", "[", 
        RowBox[{
         RowBox[{"gammaSub", "[", 
          RowBox[{"[", "i", "]"}], "]"}], "*", 
         RowBox[{"2", "^", 
          RowBox[{"(", 
           RowBox[{"v", "-", "10"}], ")"}]}]}], "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", "1", ",", "n"}], "}"}]}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"M", "[", 
      RowBox[{"[", 
       RowBox[{"1", ",", 
        RowBox[{"n", "+", "1"}]}], "]"}], "]"}], "=", "0"}], ";", 
    RowBox[{
     RowBox[{"M", "[", 
      RowBox[{"[", 
       RowBox[{"1", ",", 
        RowBox[{"n", "+", "2"}]}], "]"}], "]"}], "=", "1"}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Do", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"M", "[", 
        RowBox[{"[", 
         RowBox[{"2", ",", "i"}], "]"}], "]"}], "=", 
       RowBox[{"-", 
        RowBox[{"Floor", "[", 
         RowBox[{
          RowBox[{"psiSub", "[", 
           RowBox[{"[", "i", "]"}], "]"}], "*", 
          RowBox[{"2", "^", "v"}]}], "]"}]}]}], ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", "1", ",", "n"}], "}"}]}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"M", "[", 
      RowBox[{"[", 
       RowBox[{"2", ",", 
        RowBox[{"n", "+", "1"}]}], "]"}], "]"}], "=", 
     RowBox[{"Floor", "[", 
      RowBox[{
       RowBox[{"2", "^", "v"}], "*", 
       RowBox[{"n", "^", "4"}]}], "]"}]}], ";", 
    RowBox[{
     RowBox[{"M", "[", 
      RowBox[{"[", 
       RowBox[{"2", ",", 
        RowBox[{"n", "+", "2"}]}], "]"}], "]"}], "=", "0"}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"FIX", " ", "1"}], ":", 
     RowBox[{
      RowBox[{"Enforce", " ", "explicit", " ", "250"}], "-", 
      RowBox[{
      "digit", " ", "trigonometric", " ", "bounds", " ", "to", " ", "secure", 
       " ", "exact", " ", "lattice", " ", "coordinates"}]}]}], "*)"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Do", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"M", "[", 
        RowBox[{"[", 
         RowBox[{
          RowBox[{"i", "+", "2"}], ",", "i"}], "]"}], "]"}], "=", 
       RowBox[{"Floor", "[", 
        RowBox[{"N", "[", 
         RowBox[{
          RowBox[{"2", "*", "Pi", "*", 
           RowBox[{"2", "^", "v"}]}], ",", "250"}], "]"}], "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", "1", ",", "n"}], "}"}]}], "]"}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"reduced", "=", 
     RowBox[{"LatticeReduce", "[", "M", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<LatticeReduce complete.\>\"", "]"}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "3.", " ", "Extract", " ", "Target", " ", "Coordinate", " ", "via", " ", 
     "Vectorized", " ", "Cosine", " ", "Inspection"}], "*)"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", 
     "\"\<\\n=== 3. EXTRACTING TARGET COORDINATE VIA COSINE INSPECTION \
===\>\"", "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"validRows", "=", 
     RowBox[{"Select", "[", 
      RowBox[{"reduced", ",", 
       RowBox[{
        RowBox[{
         RowBox[{"Abs", "[", 
          RowBox[{"#", "[", 
           RowBox[{"[", 
            RowBox[{"n", "+", "2"}], "]"}], "]"}], "]"}], ">", "0"}], "&"}]}],
       "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{
     "\"\<Evaluating actual phase alignment cosines across all \>\"", ",", 
      RowBox[{"Length", "[", "validRows", "]"}], ",", 
      "\"\< lattice candidates...\>\""}], "]"}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Pre", "-", 
     RowBox[{
     "calculate", " ", "a", " ", "vectorized", " ", "local", " ", "subset", 
      " ", "for", " ", "ultra"}], "-", 
     RowBox[{"fast", " ", "candidate", " ", "checking"}]}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"With", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"subZeros", "=", 
         RowBox[{"zeros", "[", 
          RowBox[{"[", 
           RowBox[{"1", ";;", "50"}], "]"}], "]"}]}], ",", 
        RowBox[{"subAlphas", "=", 
         RowBox[{"alphas", "[", 
          RowBox[{"[", 
           RowBox[{"1", ";;", "50"}], "]"}], "]"}]}], ",", 
        RowBox[{"subPsi", "=", 
         RowBox[{"psi", "[", 
          RowBox[{"[", 
           RowBox[{"1", ";;", "50"}], "]"}], "]"}]}], ",", 
        RowBox[{"Tval", "=", 
         RowBox[{"zeros", "[", 
          RowBox[{"[", "nMax", "]"}], "]"}]}]}], "}"}], ",", 
      RowBox[{
       RowBox[{"subKernel", "=", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"Module", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"t", "=", 
              RowBox[{
               RowBox[{"Abs", "[", 
                RowBox[{"zeros", "[", 
                 RowBox[{"[", "i", "]"}], "]"}], "]"}], "/", "Tval"}]}], 
             "}"}], ",", 
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{"t", "<", "1"}], ",", 
              RowBox[{
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"1", "-", "t"}], ")"}], "*", 
                RowBox[{"Cos", "[", 
                 RowBox[{"Pi", "*", "t"}], "]"}]}], "+", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"1", "/", "Pi"}], ")"}], "*", 
                RowBox[{"Sin", "[", 
                 RowBox[{"Pi", "*", "t"}], "]"}]}]}], ",", "0"}], "]"}]}], 
           "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", "1", ",", "50"}], "}"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"preFact", "=", 
        RowBox[{"subKernel", "*", "subAlphas"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"rowEvaluations", "=", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"Module", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
             "c1", ",", "c2", ",", "candidateY0", ",", "maxLocalSum"}], "}"}],
             ",", 
            RowBox[{
             RowBox[{"c1", "=", 
              RowBox[{"row", "[", 
               RowBox[{"[", 
                RowBox[{"n", "+", "2"}], "]"}], "]"}]}], ";", 
             "\[IndentingNewLine]", 
             RowBox[{"c2", "=", 
              RowBox[{"If", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{"Floor", "[", 
                  RowBox[{
                   RowBox[{"2", "^", "v"}], "*", 
                   RowBox[{"n", "^", "4"}]}], "]"}], ">", "0"}], ",", 
                RowBox[{
                 RowBox[{"row", "[", 
                  RowBox[{"[", 
                   RowBox[{"n", "+", "1"}], "]"}], "]"}], "/", 
                 RowBox[{"Floor", "[", 
                  RowBox[{
                   RowBox[{"2", "^", "v"}], "*", 
                   RowBox[{"n", "^", "4"}]}], "]"}]}], ",", "0"}], "]"}]}], 
             ";", "\[IndentingNewLine]", 
             RowBox[{"candidateY0", "=", 
              RowBox[{"N", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{"Abs", "[", "c1", "]"}], "/", "1024"}], ",", "550"}],
                "]"}]}], ";", "\[IndentingNewLine]", 
             RowBox[{"(*", 
              RowBox[{
               RowBox[{"Lightning", " ", "fast", " ", "dot"}], "-", 
               RowBox[{
               "product", " ", "evaluation", " ", "across", " ", "a", " ", 
                "small", " ", "local", " ", "coordinate", " ", "window"}]}], 
              "*)"}], 
             RowBox[{"maxLocalSum", "=", 
              RowBox[{"Max", "[", 
               RowBox[{"Table", "[", 
                RowBox[{
                 RowBox[{
                  RowBox[{"-", "2"}], "*", 
                  RowBox[{"preFact", ".", 
                   RowBox[{"Cos", "[", 
                    RowBox[{
                    RowBox[{"subZeros", "*", 
                    RowBox[{"(", 
                    RowBox[{"candidateY0", "+", 
                    RowBox[{"k", "*", 
                    RowBox[{"1", "/", "1000"}]}]}], ")"}]}], "-", "subPsi"}], 
                    "]"}]}]}], ",", 
                 RowBox[{"{", 
                  RowBox[{"k", ",", 
                   RowBox[{"-", "10"}], ",", "10"}], "}"}]}], "]"}], "]"}]}], 
             ";", "\[IndentingNewLine]", 
             RowBox[{"{", 
              RowBox[{"row", ",", "candidateY0", ",", "maxLocalSum", ",", 
               RowBox[{"Abs", "[", "c2", "]"}]}], "}"}]}]}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"row", ",", "validRows"}], "}"}]}], "]"}]}], ";"}]}], 
     "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Sort", " ", "candidate", " ", "rows", " ", "by", " ", "the", " ", 
     "maximum", " ", "localized", " ", "peak", " ", "they", " ", "can", " ", 
     "actually", " ", "yield"}], "*)"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"sortedEvaluations", "=", 
     RowBox[{"SortBy", "[", 
      RowBox[{"rowEvaluations", ",", 
       RowBox[{
        RowBox[{"-", 
         RowBox[{"#", "[", 
          RowBox[{"[", "3", "]"}], "]"}]}], "&"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"bestEvaluation", "=", 
     RowBox[{"First", "[", "sortedEvaluations", "]"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"bestRow", "=", 
     RowBox[{"bestEvaluation", "[", 
      RowBox[{"[", "1", "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"y0", "=", 
     RowBox[{"bestEvaluation", "[", 
      RowBox[{"[", "2", "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"expectedBaseline", "=", 
     RowBox[{"bestEvaluation", "[", 
      RowBox[{"[", "3", "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"activeC2", "=", 
     RowBox[{"bestEvaluation", "[", 
      RowBox[{"[", "4", "]"}], "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", 
     "\"\<True Phase-Aligned Coordinate Successfully Isolated!\>\"", "]"}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{
     "\"\<Active Phase Coefficient (c2 value): \>\"", ",", "activeC2"}], 
     "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Peak Baseline Resonance (First 50 zeros): \>\"", ",", 
      RowBox[{"N", "[", 
       RowBox[{"expectedBaseline", ",", "6"}], "]"}]}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Base target location y0 (First 30 digits): \>\"", ",", 
      RowBox[{"NumberForm", "[", 
       RowBox[{"y0", ",", "30"}], "]"}]}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Verified tracking precision headroom of y0: \>\"", ",", 
      RowBox[{"Precision", "[", "y0", "]"}], ",", "\"\< digits.\>\""}], "]"}],
     ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"4.", " ", "Neighborhood", " ", "Grid", " ", "Search"}], "*)"}], 
   "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", 
     "\"\<\\n=== 4. EXECUTING LOCAL NEIGHBORHOOD GRID SWEEP ===\>\"", "]"}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", 
     "\"\<Pre-calculating vectorized Ingham kernel array to maximize \
execution speed...\>\"", "]"}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"T", "=", 
     RowBox[{"zeros", "[", 
      RowBox[{"[", "nMax", "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"kKernel", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"Module", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"t", "=", 
           RowBox[{
            RowBox[{"Abs", "[", 
             RowBox[{"zeros", "[", 
              RowBox[{"[", "i", "]"}], "]"}], "]"}], "/", "T"}]}], "}"}], ",", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"t", "<", "1"}], ",", 
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{"1", "-", "t"}], ")"}], "*", 
             RowBox[{"Cos", "[", 
              RowBox[{"Pi", "*", "t"}], "]"}]}], "+", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"1", "/", "Pi"}], ")"}], "*", 
             RowBox[{"Sin", "[", 
              RowBox[{"Pi", "*", "t"}], "]"}]}]}], ",", "0"}], "]"}]}], "]"}],
        ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "1", ",", "nMax"}], "}"}]}], "]"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Step", " ", "size", " ", "is", " ", "kept", " ", "as", " ", "an", " ", 
     "exact", " ", "rational", " ", "expression", " ", "to", " ", "prevent", 
     " ", "float", " ", "contamination"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"stepSize", "=", 
     RowBox[{"1", "/", "1000"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"samples", "=", "200"}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
     "gridPoints", " ", "automatically", " ", "inherits", " ", "the", " ", 
      "full", " ", "550"}], "-", 
     RowBox[{"digit", " ", "depth", " ", "from", " ", "y0"}]}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"gridPoints", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"y0", "+", 
        RowBox[{"k", "*", "stepSize"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"k", ",", 
         RowBox[{
          RowBox[{"-", "samples"}], "/", "2"}], ",", 
         RowBox[{"samples", "/", "2"}]}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{"UPGRADE", " ", "2"}], ":", 
      RowBox[{"Batch", "-", 
       RowBox[{"elevate", " ", "all", " ", "100"}]}]}], ",", 
     RowBox[{
     "000", " ", "vectors", " ", "to", " ", "550", " ", "digits", " ", 
      "before", " ", "starting", " ", "the", " ", "grid", " ", "loop"}]}], 
    "*)"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", 
     "\"\<Pre-allocating 550-digit precision tracking containers for grid \
search...\>\"", "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"zerosHigh", "=", 
     RowBox[{"SetPrecision", "[", 
      RowBox[{"zeros", ",", "550"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"psiHigh", "=", 
     RowBox[{"SetPrecision", "[", 
      RowBox[{"psi", ",", "550"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"alphasHigh", "=", 
     RowBox[{"SetPrecision", "[", 
      RowBox[{"alphas", ",", "550"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"kKernelHigh", "=", 
     RowBox[{"SetPrecision", "[", 
      RowBox[{"kKernel", ",", "550"}], "]"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
     "Function", " ", "to", " ", "evaluate", " ", "hK", " ", "safely", " ", 
      "using", " ", "lightning"}], "-", 
     RowBox[{"fast", " ", "vector"}], "-", 
     RowBox[{"linear", " ", "algebra"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"evaluateHK", "[", "yVal_", "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"yHigh", ",", "sumVal"}], "}"}], ",", 
       RowBox[{
        RowBox[{"yHigh", "=", 
         RowBox[{"SetPrecision", "[", 
          RowBox[{"yVal", ",", "550"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{
         "Replaced", " ", "slow", " ", "nested", " ", "loops", " ", "with", 
          " ", "vectorized", " ", "Total", " ", "multiplication", " ", 
          "pass"}], "*)"}], 
        RowBox[{"sumVal", "=", 
         RowBox[{
          RowBox[{"-", "2"}], "*", 
          RowBox[{"Total", "[", 
           RowBox[{"kKernelHigh", "*", "alphasHigh", "*", 
            RowBox[{"Cos", "[", 
             RowBox[{
              RowBox[{"zerosHigh", "*", "yHigh"}], "-", "psiHigh"}], "]"}]}], 
           "]"}]}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"N", "[", 
         RowBox[{"sumVal", ",", "20"}], "]"}]}]}], "]"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", 
     "\"\<Sweeping local window around y0 to locate the true wave \
peak...\>\"", "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"results", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"y", ",", 
         RowBox[{"evaluateHK", "[", "y", "]"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"y", ",", "gridPoints"}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Find", " ", "the", " ", "absolute", " ", "maximum", " ", "peak", " ", 
     "in", " ", "this", " ", "local", " ", "neighborhood"}], "*)"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"sortedResults", "=", 
     RowBox[{"SortBy", "[", 
      RowBox[{"results", ",", 
       RowBox[{
        RowBox[{"-", 
         RowBox[{"#", "[", 
          RowBox[{"[", "2", "]"}], "]"}]}], "&"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"bestMatch", "=", 
     RowBox[{"First", "[", "sortedResults", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"peakY", "=", 
     RowBox[{"bestMatch", "[", 
      RowBox[{"[", "1", "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"peakValue", "=", 
     RowBox[{"bestMatch", "[", 
      RowBox[{"[", "2", "]"}], "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<\\n=== FINAL VERIFICATION RESULTS ===\>\"", "]"}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Highest localized peak found at y: \>\"", ",", 
      RowBox[{"ScientificForm", "[", 
       RowBox[{"N", "[", 
        RowBox[{"peakY", ",", "20"}], "]"}], "]"}]}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Maximum verified value of hK(y): \>\"", ",", 
      RowBox[{"InputForm", "[", "peakValue", "]"}]}], "]"}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"N", "[", "peakValue", "]"}], ">", "1.0"}], ",", 
      RowBox[{"Print", "[", 
       RowBox[{
       "\"\<[checkmark] SUCCESS: The wave peak reaches \>\"", ",", 
        "peakValue", ",", 
        "\"\<, which breaks the 1.0 barrier! The Mertens Conjecture is false.\
\>\""}], "]"}], ",", 
      RowBox[{
      "Print", "[", 
       "\"\<\:2717 Peak did not clear 1.0. The neighborhood window needs to \
be widened or step size refined.\>\"", "]"}]}], "]"}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"FIX", " ", "3"}], ":", 
     RowBox[{
      RowBox[{
      "Wrap", " ", "results", " ", "array", " ", "in", " ", "standard", " ", 
       "N", " ", "to", " ", "bypass", " ", "frontend", " ", "UI", " ", 
       "rendering", " ", "lags", " ", "with", " ", "high"}], "-", 
      RowBox[{"precision", " ", "floats"}]}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"ListLinePlot", "[", 
    RowBox[{
     RowBox[{"N", "[", 
      RowBox[{"results", "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", "2"}], "]"}], "]"}], "]"}], ",", 
     RowBox[{"PlotLabel", "->", "\"\<Local Wave Interference Near y0\>\""}], 
     ",", 
     RowBox[{"AxesLabel", "->", 
      RowBox[{"{", 
       RowBox[{"\"\<Sample Index\>\"", ",", "\"\<hK(y)\>\""}], "}"}]}], ",", 
     RowBox[{"GridLines", "->", "Automatic"}], ",", 
     RowBox[{"PlotRange", "->", "All"}]}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.9898884040173397`*^9, 3.98988840403762*^9}, 
