Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Block", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
    "activeZeros", ",", "activePhases", ",", "activeY", ",", "cosines", ",", 
     "runningSums", ",", "runningMeans"}], "}"}], ",", 
   RowBox[{"(*", 
    RowBox[{
    "1.", " ", "Dynamically", " ", "locate", " ", "the", " ", "active", " ", 
     "arrays"}], "*)"}], 
   RowBox[{
    RowBox[{"activeZeros", "=", 
     RowBox[{"Which", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"ListQ", "[", "zeros", "]"}], "&&", 
        RowBox[{
         RowBox[{"Length", "[", "zeros", "]"}], ">", "0"}]}], ",", "zeros", 
       ",", 
       RowBox[{
        RowBox[{"ListQ", "[", "gamma", "]"}], "&&", 
        RowBox[{
         RowBox[{"Length", "[", "gamma", "]"}], ">", "0"}]}], ",", "gamma", 
       ",", 
       RowBox[{
        RowBox[{"ListQ", "[", "zerosRaw", "]"}], "&&", 
        RowBox[{
         RowBox[{"Length", "[", "zerosRaw", "]"}], ">", "0"}]}], ",", 
       "zerosRaw", ",", "True", ",", "$Failed"}], "]"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"activePhases", "=", 
     RowBox[{"Which", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"ListQ", "[", "args", "]"}], "&&", 
        RowBox[{
         RowBox[{"Length", "[", "args", "]"}], ">", "0"}]}], ",", "args", ",", 
       RowBox[{
        RowBox[{"ListQ", "[", "phases", "]"}], "&&", 
        RowBox[{
         RowBox[{"Length", "[", "phases", "]"}], ">", "0"}]}], ",", "phases", 
       ",", 
       RowBox[{
        RowBox[{"ListQ", "[", "psi", "]"}], "&&", 
        RowBox[{
         RowBox[{"Length", "[", "psi", "]"}], ">", "0"}]}], ",", "psi", ",", 
       "True", ",", "$Failed"}], "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"activeY", "=", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"NumericQ", "[", "y0", "]"}], ",", "y0", ",", 
       RowBox[{"1.953259631555304", "*", 
        RowBox[{"10", "^", "237"}]}]}], "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"(*", 
     RowBox[{"2.", " ", "Execution", " ", "and", " ", "Diagnostic"}], "*)"}], 
    
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"activeZeros", "===", "$Failed"}], "||", 
       RowBox[{"activePhases", "===", "$Failed"}]}], ",", 
      RowBox[{
      "Print", "[", "\"\<Error: Could not locate your data lists.\>\"", "]"}],
       ",", 
      RowBox[{"With", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"maxTerms", "=", 
          RowBox[{"Min", "[", 
           RowBox[{"70", ",", 
            RowBox[{"Length", "[", "activeZeros", "]"}], ",", 
            RowBox[{"Length", "[", "activePhases", "]"}]}], "]"}]}], "}"}], 
        ",", 
        RowBox[{
         RowBox[{"Print", "[", 
          RowBox[{
          "\"\<Computing \>\"", ",", "maxTerms", ",", 
           "\"\< dominant harmonic components...\>\""}], "]"}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"(*", 
          RowBox[{
          "Generate", " ", "the", " ", "list", " ", "of", " ", "cosines"}], 
          "*)"}], 
         RowBox[{"cosines", "=", 
          RowBox[{
           RowBox[{"Table", "[", 
            RowBox[{
             RowBox[{"Cos", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"activeZeros", "[", 
                 RowBox[{"[", "i", "]"}], "]"}], "*", "activeY"}], "-", 
               RowBox[{"activePhases", "[", 
                RowBox[{"[", "i", "]"}], "]"}]}], "]"}], ",", 
             RowBox[{"{", 
              RowBox[{"i", ",", "1", ",", "maxTerms"}], "}"}]}], "]"}], "//", 
           "N"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"(*", 
          RowBox[{
          "Run", " ", "the", " ", "Harmonic", " ", "Stability", " ", 
           "Analyzer"}], "*)"}], 
         RowBox[{"runningSums", "=", 
          RowBox[{"Accumulate", "[", "cosines", "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"runningMeans", "=", 
          RowBox[{"Table", "[", 
           RowBox[{
            RowBox[{"Mean", "[", 
             RowBox[{"Take", "[", 
              RowBox[{"cosines", ",", "i"}], "]"}], "]"}], ",", 
            RowBox[{"{", 
             RowBox[{"i", ",", "1", ",", "maxTerms"}], "}"}]}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"Print", "[", 
          RowBox[{"\"\<Final Harmonic Sum (70 terms): \>\"", ",", 
           RowBox[{"Last", "[", "runningSums", "]"}]}], "]"}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"Print", "[", 
          RowBox[{"\"\<Mean Harmonic Stability: \>\"", ",", 
           RowBox[{"Last", "[", "runningMeans", "]"}]}], "]"}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"Print", "[", 
          RowBox[{"ListLinePlot", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"runningSums", ",", 
              RowBox[{"runningMeans", "*", "50"}]}], "}"}], ",", 
            RowBox[{"PlotLegends", "->", 
             RowBox[{"{", 
              RowBox[{
              "\"\<Cumulative Interference\>\"", ",", 
               "\"\<Scaled Running Mean (x50)\>\""}], "}"}]}], ",", 
            RowBox[{
            "PlotLabel", "->", 
             "\"\<Dynamical Stability of the Zeta Spectrum\>\""}], ",", 
            RowBox[{"AxesLabel", "->", 
             RowBox[{"{", 
              RowBox[{"\"\<Number of Zeros\>\"", ",", "\"\<Magnitude\>\""}], 
              "}"}]}], ",", 
            RowBox[{"PlotRange", "->", "All"}], ",", 
            RowBox[{"ImageSize", "->", "Medium"}]}], "]"}], "]"}]}]}], 
       "]"}]}], "]"}]}]}], "]"}]], "Input",
 CellChangeTimes->{{3.991678478291761*^9, 3.991678478318283*^9}},
