             ";", "\[IndentingNewLine]", 
             RowBox[{"candidateY0", "=", 
              RowBox[{"N", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{"Abs", "[", "c1", "]"}], "/", "1024"}], ",", "550"}],
                "]"}]}], ";", "\[IndentingNewLine]", 
             RowBox[{"(*", 
