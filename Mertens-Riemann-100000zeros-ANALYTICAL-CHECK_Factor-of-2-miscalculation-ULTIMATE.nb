          RowBox[{"Module", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"t", "=", 
              RowBox[{
               RowBox[{"Abs", "[", 
                RowBox[{"zeros", "[", 
                 RowBox[{"[", "i", "]"}], "]"}], "]"}], "/", "Tval"}]}], 
