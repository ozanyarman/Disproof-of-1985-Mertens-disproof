Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"::", "Title", "::"}], "*)"}], 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"Pure", " ", "Phase"}], "-", 
    RowBox[{"Alignment", " ", 
     RowBox[{"Verification", ":", 
      RowBox[{
      "Bypassing", " ", "Giant", " ", "Integer", " ", "Destruction"}]}]}]}], 
   "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"ClearAll", "[", "\"\<Global`*\>\"", "]"}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
    "SetDirectory", "[", 
     "\"\</Users/ozanyarman/Documents/Wolfram Mathematica/\>\"", "]"}], ";"}],
    "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", 
     "\"\<=== 1. LOADING DATA WITH EXPLICIT PRECISION GUARD ===\>\"", "]"}], 
    ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"High", "-", 
     RowBox[{"precision", " ", "string"}], "-", 
     RowBox[{
     "safe", " ", "importer", " ", "to", " ", "handle", " ", "space"}], "-", 
     RowBox[{"separated", " ", "formatting"}]}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"ImportHighPrec", "[", "fileName_", "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"rawText", ",", "stringTokens"}], "}"}], ",", 
       RowBox[{
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"Not", "[", 
           RowBox[{"FileExistsQ", "[", "fileName", "]"}], "]"}], ",", 
          RowBox[{
           RowBox[{"Print", "[", 
            RowBox[{
            "\"\<ERROR: \>\"", ",", "fileName", ",", "\"\< not found!\>\""}], 
            "]"}], ";", 
           RowBox[{"Abort", "[", "]"}]}]}], "]"}], ";", "\[IndentingNewLine]", 
        RowBox[{"rawText", "=", 
         RowBox[{"Import", "[", 
          RowBox[{"fileName", ",", "\"\<String\>\""}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"stringTokens", "=", 
         RowBox[{"StringSplit", "[", "rawText", "]"}]}], ";", 
        RowBox[{"(*", 
         RowBox[{
          RowBox[{"Splits", " ", "cleanly", " ", "by", " ", "spaces"}], ",", 
          "tabs", ",", 
          RowBox[{"or", " ", "newlines"}]}], "*)"}], 
        RowBox[{"Map", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"ToExpression", "[", 
            RowBox[{"#", "<>", "\"\<`250\>\""}], "]"}], "&"}], ",", 
          "stringTokens"}], "]"}]}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   "\n", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<Parsing zeros...\>\"", "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"zeros", "=", 
     RowBox[{"ImportHighPrec", "[", "\"\<high_prec_zeros.txt\>\"", "]"}]}], 
    ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<Parsing amplitudes (alphas)...\>\"", "]"}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"alphas", "=", 
     RowBox[{"ImportHighPrec", "[", "\"\<high_prec_alpha.txt\>\"", "]"}]}], 
    ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<Parsing phases (psi)...\>\"", "]"}], ";"}], 
   "\n", 
   RowBox[{
    RowBox[{"psi", "=", 
     RowBox[{"ImportHighPrec", "[", "\"\<high_prec_arg.txt\>\"", "]"}]}], 
    ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"nMax", "=", 
     RowBox[{"Length", "[", "zeros", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"T", "=", 
     RowBox[{"zeros", "[", 
      RowBox[{"[", "nMax", "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<Pre-calculating Ingham kernel weights...\>\"", "]"}], 
    ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Maintained", " ", "pure", " ", "high"}], "-", 
     RowBox[{"precision", " ", "evaluation", " ", "vectors"}]}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"kKernel", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"1", "-", 
           RowBox[{
            RowBox[{"zeros", "[", 
             RowBox[{"[", "i", "]"}], "]"}], "/", "T"}]}], ")"}], "*", 
         RowBox[{"Cos", "[", 
          RowBox[{"Pi", "*", 
           RowBox[{
            RowBox[{"zeros", "[", 
             RowBox[{"[", "i", "]"}], "]"}], "/", "T"}]}], "]"}]}], "+", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"1", "/", "Pi"}], ")"}], "*", 
         RowBox[{"Sin", "[", 
          RowBox[{"Pi", "*", 
           RowBox[{
            RowBox[{"zeros", "[", 
             RowBox[{"[", "i", "]"}], "]"}], "/", "T"}]}], "]"}]}]}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "1", ",", "nMax"}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", 
     "\"\<\\n=== 2. LOCATING THE HISTORICAL 1985 ALIGNMENT REGION ===\>\"", 
     "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"dominantIndices", "=", 
     RowBox[{"Ordering", "[", 
      RowBox[{"alphas", ",", 
       RowBox[{"-", "5"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Dominant zero frequencies: \>\"", ",", 
      RowBox[{"N", "[", 
       RowBox[{
        RowBox[{"zeros", "[", 
         RowBox[{"[", "dominantIndices", "]"}], "]"}], ",", "4"}], "]"}]}], 
     "]"}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<Scanning precision-safe phase intersections...\>\"", 
     "]"}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"FIX", " ", "1"}], ":", 
     RowBox[{
      RowBox[{
      "Swapped", " ", "out", " ", "machine", " ", "float", " ", "0.005", " ", 
       "for", " ", "exact", " ", "rational", " ", 
       RowBox[{"1", "/", "200"}], " ", "to", " ", "safeguard", " ", "250"}], 
      "-", 
      RowBox[{"digit", " ", "tracking"}]}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"stepSize", "=", 
     RowBox[{"1", "/", "200"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"searchRange", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"100000", "+", 
        RowBox[{"k", "*", "stepSize"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"k", ",", "0", ",", "50000"}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"maxVal", "=", 
     RowBox[{"-", "Infinity"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"bestY", "=", "0"}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Dense", " ", "localized", " ", "scan", " ", "using", " ", "the", " ", 
     "first", " ", "50", " ", "zeros", " ", "to", " ", "keep", " ", "the", 
     " ", "initial", " ", "pass", " ", "rapid"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Do", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"y", "=", 
        RowBox[{"searchRange", "[", 
         RowBox[{"[", "k", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"currentVal", "=", 
        RowBox[{
         RowBox[{"-", "2"}], "*", 
         RowBox[{"Sum", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"kKernel", "[", 
             RowBox[{"[", "i", "]"}], "]"}], "*", 
            RowBox[{"alphas", "[", 
             RowBox[{"[", "i", "]"}], "]"}], "*", 
            RowBox[{"Cos", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"zeros", "[", 
                RowBox[{"[", "i", "]"}], "]"}], "*", "y"}], "-", 
              RowBox[{"psi", "[", 
               RowBox[{"[", "i", "]"}], "]"}]}], "]"}]}], ",", 
           RowBox[{"{", 
            RowBox[{"i", ",", "1", ",", "50"}], "}"}]}], "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"currentVal", ">", "maxVal"}], ",", 
         RowBox[{
          RowBox[{"maxVal", "=", "currentVal"}], ";", 
          RowBox[{"bestY", "=", "y"}], ";"}]}], "]"}], ";"}], ",", 
      RowBox[{"{", 
       RowBox[{"k", ",", "1", ",", 
        RowBox[{"Length", "[", "searchRange", "]"}]}], "}"}]}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<\\nBest baseline candidate found at y = \>\"", ",", 
      RowBox[{"N", "[", 
       RowBox[{"bestY", ",", "15"}], "]"}]}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Baseline value (first 50 zeros): \>\"", ",", 
      RowBox[{"N", "[", 
       RowBox[{"maxVal", ",", "10"}], "]"}]}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"3.", " ", "High"}], "-", 
     RowBox[{
     "Precision", " ", "Hill", " ", "Climb", " ", "from", " ", "the", " ", 
      "Baseline", " ", "Point"}]}], "*)"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<\\n=== 3. RUNNING EXACT SPECTRUM CLIMBER ===\>\"", 
     "]"}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{"UPGRADE", " ", "1"}], ":", 
      RowBox[{"Batch", "-", 
       RowBox[{"elevate", " ", "entire", " ", "100"}]}]}], ",", 
     RowBox[{
      RowBox[{"000", " ", "point", " ", "arrays", " ", "into", " ", "550"}], 
      "-", 
      RowBox[{
      "digit", " ", "containers", " ", "to", " ", "provide", " ", "a", " ", 
       "deep", " ", "precision", " ", "buffer", " ", "before", " ", 
       "entering", " ", "the", " ", "heavy", " ", "optimization", " ", 
       "phase"}]}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", 
     "\"\<Pre-allocating 550-digit precision tracking containers for hill \
ascent...\>\"", "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"zerosHigh", "=", 
     RowBox[{"SetPrecision", "[", 
      RowBox[{"zeros", ",", "550"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"psiHigh", "=", 
     RowBox[{"SetPrecision", "[", 
      RowBox[{"psi", ",", "550"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"alphasHigh", "=", 
     RowBox[{"SetPrecision", "[", 
      RowBox[{"alphas", ",", "550"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"kKernelHigh", "=", 
     RowBox[{"SetPrecision", "[", 
      RowBox[{"kKernel", ",", "550"}], "]"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"UPGRADE", " ", "2"}], ":", 
     RowBox[{
      RowBox[{
      "Scale", " ", "the", " ", "isolated", " ", "coordinate", " ", "cleanly",
        " ", "up", " ", "to", " ", "the", " ", "550"}], "-", 
      RowBox[{"digit", " ", "environment"}]}]}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"currentY", "=", 
     RowBox[{"N", "[", 
      RowBox[{"bestY", ",", "550"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", 
     "\"\<Executing Newton-Raphson spectrum maximization loop (30 \
iterations)...\>\"", "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Do", "[", 
     RowBox[{"(*", 
      RowBox[{"Vectorized", " ", "Optimization", " ", 
       RowBox[{"Block", ":", 
        RowBox[{
        "Evaluates", " ", "angles", " ", "and", " ", "trigonometric", " ", 
         "sets", " ", "globally"}]}]}], "*)"}], 
     RowBox[{
      RowBox[{
       RowBox[{"Module", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
          "angles", ",", "cosArray", ",", "sinArray", ",", "deriv1", ",", 
           "deriv2", ",", "step"}], "}"}], ",", 
         RowBox[{
          RowBox[{"angles", "=", 
           RowBox[{
            RowBox[{"zerosHigh", "*", "currentY"}], "-", "psiHigh"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"cosArray", "=", 
           RowBox[{"Cos", "[", "angles", "]"}]}], ";", "\[IndentingNewLine]", 
          
          RowBox[{"sinArray", "=", 
           RowBox[{"Sin", "[", "angles", "]"}]}], ";", "\[IndentingNewLine]", 
          
          RowBox[{"(*", 
           RowBox[{"First", " ", "Derivative", " ", 
            RowBox[{"(", 
             RowBox[{"f", "'"}], ")"}]}], "*)"}], 
          RowBox[{"deriv1", "=", 
           RowBox[{"2", "*", 
            RowBox[{"Sum", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"kKernelHigh", "[", 
                RowBox[{"[", "i", "]"}], "]"}], "*", 
               RowBox[{"alphasHigh", "[", 
                RowBox[{"[", "i", "]"}], "]"}], "*", 
               RowBox[{"zerosHigh", "[", 
                RowBox[{"[", "i", "]"}], "]"}], "*", 
               RowBox[{"sinArray", "[", 
                RowBox[{"[", "i", "]"}], "]"}]}], ",", 
              RowBox[{"{", 
               RowBox[{"i", ",", "1", ",", "nMax"}], "}"}]}], "]"}]}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{"Second", " ", "Derivative", " ", 
            RowBox[{"(", 
             RowBox[{"f", "''"}], ")"}]}], "*)"}], 
          RowBox[{"deriv2", "=", 
           RowBox[{"2", "*", 
            RowBox[{"Sum", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"kKernelHigh", "[", 
                RowBox[{"[", "i", "]"}], "]"}], "*", 
               RowBox[{"alphasHigh", "[", 
                RowBox[{"[", "i", "]"}], "]"}], "*", 
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"zerosHigh", "[", 
                  RowBox[{"[", "i", "]"}], "]"}], "^", "2"}], ")"}], "*", 
               RowBox[{"cosArray", "[", 
                RowBox[{"[", "i", "]"}], "]"}]}], ",", 
              RowBox[{"{", 
               RowBox[{"i", ",", "1", ",", "nMax"}], "}"}]}], "]"}]}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{
            RowBox[{"Execute", " ", "the", " ", "Newton"}], "-", 
            RowBox[{"Raphson", " ", "update", " ", "step"}]}], "*)"}], 
          RowBox[{"step", "=", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"Abs", "[", "deriv2", "]"}], ">", "0"}], ",", 
             RowBox[{"deriv1", "/", "deriv2"}], ",", "0"}], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{
            RowBox[{"FIX", " ", "3"}], ":", 
            RowBox[{
            "Replaced", " ", "machine", " ", "float", " ", "0.01", " ", 
             "threshold", " ", "with", " ", "exact", " ", "rational", " ", 
             RowBox[{"1", "/", "100"}]}]}], "*)"}], 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"Abs", "[", "step", "]"}], ">", 
             RowBox[{"1", "/", "100"}]}], ",", 
            RowBox[{"step", "=", 
             RowBox[{
              RowBox[{"Sign", "[", "step", "]"}], "*", 
              RowBox[{"(", 
               RowBox[{"1", "/", "100"}], ")"}]}]}]}], "]"}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"currentY", "=", 
           RowBox[{"currentY", "-", "step"}]}], ";"}]}], "]"}], ";"}], ",", 
      RowBox[{"{", 
       RowBox[{"iter", ",", "1", ",", "30"}], "}"}]}], "]"}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
     "Final", " ", "verification", " ", "evaluation", " ", "locked", " ", 
      "completely", " ", "at", " ", "550"}], "-", 
     RowBox[{"digit", " ", "arbitrary", " ", "precision"}]}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"finalPeak", "=", 
     RowBox[{
      RowBox[{"-", "2"}], "*", 
      RowBox[{"Sum", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"kKernelHigh", "[", 
          RowBox[{"[", "i", "]"}], "]"}], "*", 
         RowBox[{"alphasHigh", "[", 
          RowBox[{"[", "i", "]"}], "]"}], "*", 
         RowBox[{"Cos", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"zerosHigh", "[", 
             RowBox[{"[", "i", "]"}], "]"}], "*", "currentY"}], "-", 
           RowBox[{"psiHigh", "[", 
            RowBox[{"[", "i", "]"}], "]"}]}], "]"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", "1", ",", "nMax"}], "}"}]}], "]"}]}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<\\n=== FINAL VERIFICATION RESULTS ===\>\"", "]"}], 
    ";"}], "\n", 
