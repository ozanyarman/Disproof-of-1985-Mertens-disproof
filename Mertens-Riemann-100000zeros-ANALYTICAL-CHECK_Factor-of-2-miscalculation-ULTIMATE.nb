                    "]"}]}]}], ",", 
                 RowBox[{"{", 
                  RowBox[{"k", ",", 
                   RowBox[{"-", "10"}], ",", "10"}], "}"}]}], "]"}], "]"}]}], 
             ";", "\[IndentingNewLine]", 
             RowBox[{"{", 
              RowBox[{"row", ",", "candidateY0", ",", "minLocalSum", ",", 
