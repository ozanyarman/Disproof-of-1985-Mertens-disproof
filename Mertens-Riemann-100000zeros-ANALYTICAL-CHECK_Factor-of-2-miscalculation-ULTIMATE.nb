                 RowBox[{
                  RowBox[{"-", "2"}], "*", 
                  RowBox[{"preFact", ".", 
                   RowBox[{"Cos", "[", 
                    RowBox[{
                    RowBox[{"subZeros", "*", 
                    RowBox[{"(", 
                    RowBox[{"candidateY0", "+", 
                    RowBox[{"k", "*", 
                    RowBox[{"2", "/", "100"}]}]}], ")"}]}], "-", "subPsi"}], 
                    "]"}]}]}], ",", 
                 RowBox[{"{", 
                  RowBox[{"k", ",", 
                   RowBox[{"-", "10"}], ",", "10"}], "}"}]}], "]"}], "]"}]}], 
