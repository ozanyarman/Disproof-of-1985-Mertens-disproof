Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Block", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"activeZeros", ",", "activePhases", ",", "activeY"}], "}"}], ",", 
   
   RowBox[{"(*", 
    RowBox[{
    "1.", " ", "Dynamically", " ", "locate", " ", "the", " ", "active", " ", 
     "zeros", " ", "array"}], "*)"}], 
   RowBox[{
    RowBox[{"activeZeros", "=", 
     RowBox[{"Which", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"ListQ", "[", "zeros", "]"}], "&&", 
        RowBox[{
         RowBox[{"Length", "[", "zeros", "]"}], ">", "0"}]}], ",", "zeros", 
       ",", 
       RowBox[{
        RowBox[{"ListQ", "[", "gamma", "]"}], "&&", 
        RowBox[{
         RowBox[{"Length", "[", "gamma", "]"}], ">", "0"}]}], ",", "gamma", 
       ",", 
       RowBox[{
        RowBox[{"ListQ", "[", "zerosRaw", "]"}], "&&", 
        RowBox[{
         RowBox[{"Length", "[", "zerosRaw", "]"}], ">", "0"}]}], ",", 
       "zerosRaw", ",", "True", ",", "$Failed"}], "]"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"(*", 
     RowBox[{
     "2.", " ", "Dynamically", " ", "locate", " ", "the", " ", "active", " ", 
      
      RowBox[{"phase", "/", "argument"}], " ", "array"}], "*)"}], 
    RowBox[{"activePhases", "=", 
     RowBox[{"Which", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"ListQ", "[", "args", "]"}], "&&", 
        RowBox[{
         RowBox[{"Length", "[", "args", "]"}], ">", "0"}]}], ",", "args", ",", 
       RowBox[{
        RowBox[{"ListQ", "[", "phases", "]"}], "&&", 
        RowBox[{
         RowBox[{"Length", "[", "phases", "]"}], ">", "0"}]}], ",", "phases", 
       ",", 
       RowBox[{
        RowBox[{"ListQ", "[", "psi", "]"}], "&&", 
        RowBox[{
         RowBox[{"Length", "[", "psi", "]"}], ">", "0"}]}], ",", "psi", ",", 
       "True", ",", "$Failed"}], "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"(*", 
     RowBox[{"3.", " ", "Capture", " ", "the", " ", "coordinate"}], "*)"}], 
    RowBox[{"activeY", "=", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"NumericQ", "[", "y0", "]"}], ",", "y0", ",", 
       RowBox[{"1.953259631555304", "*", 
        RowBox[{"10", "^", "237"}]}]}], "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"(*", 
     RowBox[{
     "4.", " ", "Output", " ", "diagnostics", " ", "so", " ", "we", " ", 
      "know", " ", "what", " ", "was", " ", "found"}], "*)"}], 
    RowBox[{"Print", "[", 
     RowBox[{"\"\<[Diagnostic] Found Zeros Data In: \>\"", ",", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"activeZeros", "===", "$Failed"}], ",", "\"\<NOT FOUND\>\"", 
        ",", 
        RowBox[{"SymbolName", "[", 
         RowBox[{"Unevaluated", "[", "activeZeros", "]"}], "]"}]}], "]"}]}], 
     "]"}], ";", "\[IndentingNewLine]", 
    RowBox[{"Print", "[", 
     RowBox[{"\"\<[Diagnostic] Found Phase Data In: \>\"", ",", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"activePhases", "===", "$Failed"}], ",", "\"\<NOT FOUND\>\"", 
        ",", 
        RowBox[{"SymbolName", "[", 
         RowBox[{"Unevaluated", "[", "activePhases", "]"}], "]"}]}], "]"}]}], 
     "]"}], ";", "\[IndentingNewLine]", 
    RowBox[{"Print", "[", 
     RowBox[{
     "\"\<[Diagnostic] Evaluating at Coordinate: y0 = \>\"", ",", "activeY"}],
      "]"}], ";", "\[IndentingNewLine]", 
    RowBox[{
    "Print", "[", 
     "\"\<------------------------------------------------------------\>\"", 
     "]"}], ";", "\[IndentingNewLine]", 
    RowBox[{"(*", 
     RowBox[{
     "5.", " ", "Execute", " ", "the", " ", "ultimate", " ", "verdict", " ", 
      "test"}], "*)"}], 
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"activeZeros", "===", "$Failed"}], "||", 
       RowBox[{"activePhases", "===", "$Failed"}]}], ",", 
      RowBox[{
      "Print", "[", 
       "\"\<Error: Could not locate your data lists. Please ensure your \
import scripts have been run in this session.\>\"", "]"}], ",", 
      RowBox[{"With", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"maxTerms", "=", 
          RowBox[{"Min", "[", 
           RowBox[{"70", ",", 
            RowBox[{"Length", "[", "activeZeros", "]"}], ",", 
            RowBox[{"Length", "[", "activePhases", "]"}]}], "]"}]}], "}"}], 
        ",", 
        RowBox[{
         RowBox[{"Print", "[", 
          RowBox[{
          "\"\<Computing individual cosines for the top \>\"", ",", 
           "maxTerms", ",", "\"\< dominant frequencies:\>\""}], "]"}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"Table", "[", 
           RowBox[{
            RowBox[{"Cos", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"activeZeros", "[", 
                RowBox[{"[", "i", "]"}], "]"}], "*", "activeY"}], "-", 
              RowBox[{"activePhases", "[", 
               RowBox[{"[", "i", "]"}], "]"}]}], "]"}], ",", 
            RowBox[{"{", 
             RowBox[{"i", ",", "1", ",", "maxTerms"}], "}"}]}], "]"}], "//", 
          "N"}]}]}], "]"}]}], "]"}]}]}], "]"}]], "Input",
 CellChangeTimes->{{3.991197521951748*^9, 3.991197521970026*^9}},
