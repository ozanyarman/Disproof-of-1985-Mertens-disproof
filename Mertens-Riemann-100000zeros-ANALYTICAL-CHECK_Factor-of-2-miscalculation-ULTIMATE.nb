   RowBox[{
    RowBox[{"stepSize", "=", 
     RowBox[{"2", "/", "100"}]}], ";", 
    RowBox[{"(*", 
     RowBox[{"Locked", " ", "0.02", " ", "step"}], "*)"}], 
    RowBox[{"samples", "=", "200"}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
