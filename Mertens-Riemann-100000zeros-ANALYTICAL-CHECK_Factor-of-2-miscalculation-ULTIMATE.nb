Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"::", "Title", "::"}], "*)"}], 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
     RowBox[{
     "Repaired", " ", "1985", " ", "Mertens", " ", "Disproof", " ", 
      "Replication"}], "&"}], " ", "Wide", " ", "Grid", " ", 
    RowBox[{"Sweep", ":", 
     RowBox[{"Negative", " ", "Range"}]}]}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"ClearAll", "[", "\"\<Global`*\>\"", "]"}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "1.", " ", "Configure", " ", "Directories", " ", "and", " ", "Load", " ", 
     "Data"}], "*)"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
    "SetDirectory", "[", 
     "\"\</Users/apple/Documents/Wolfram Mathematica/\>\"", "]"}], ";"}], 
   "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", 
     "\"\<=== 1. LOADING DATA WITH EXPLICIT PRECISION GUARD ===\>\"", "]"}], 
    ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"High", "-", 
     RowBox[{"precision", " ", "string"}], "-", 
     RowBox[{
     "safe", " ", "importer", " ", "to", " ", "handle", " ", "space"}], "-", 
     RowBox[{"separated", " ", "formatting"}]}], "*)"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"ImportHighPrec", "[", "fileName_", "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"rawText", ",", "stringTokens"}], "}"}], ",", 
       RowBox[{
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"Not", "[", 
           RowBox[{"FileExistsQ", "[", "fileName", "]"}], "]"}], ",", 
          RowBox[{
           RowBox[{"Print", "[", 
            RowBox[{
            "\"\<ERROR: \>\"", ",", "fileName", ",", "\"\< not found!\>\""}], 
            "]"}], ";", 
           RowBox[{"Abort", "[", "]"}]}]}], "]"}], ";", "\[IndentingNewLine]", 
        RowBox[{"rawText", "=", 
         RowBox[{"Import", "[", 
          RowBox[{"fileName", ",", "\"\<String\>\""}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"stringTokens", "=", 
         RowBox[{"StringSplit", "[", "rawText", "]"}]}], ";", 
        RowBox[{"(*", 
         RowBox[{
          RowBox[{"Splits", " ", "cleanly", " ", "by", " ", "spaces"}], ",", 
          "tabs", ",", 
          RowBox[{"or", " ", "newlines"}]}], "*)"}], 
        RowBox[{"Map", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"ToExpression", "[", 
            RowBox[{"#", "<>", "\"\<`250\>\""}], "]"}], "&"}], ",", 
          "stringTokens"}], "]"}]}]}], "]"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<Parsing zeros...\>\"", "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"zeros", "=", 
     RowBox[{"ImportHighPrec", "[", "\"\<high_prec_zeros.txt\>\"", "]"}]}], 
    ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<Parsing amplitudes (alphas)...\>\"", "]"}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"alphas", "=", 
     RowBox[{"ImportHighPrec", "[", "\"\<high_prec_alpha.txt\>\"", "]"}]}], 
    ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<Parsing phases (psi)...\>\"", "]"}], ";"}], 
   "\n", 
   RowBox[{
    RowBox[{"psi", "=", 
     RowBox[{"ImportHighPrec", "[", "\"\<high_prec_arg.txt\>\"", "]"}]}], 
    ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"nMax", "=", 
     RowBox[{"Length", "[", "zeros", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"n", "=", "70"}], ";", 
    RowBox[{"(*", 
     RowBox[{
      RowBox[{"Standard", " ", "70"}], "-", 
      RowBox[{
      "dimension", " ", "matrix", " ", "from", " ", "the", " ", "paper"}]}], 
     "*)"}], 
    RowBox[{"Print", "[", 
     RowBox[{
     "\"\<Loaded \>\"", ",", "nMax", ",", 
      "\"\< total zeros. Selected subset size for LLL: \>\"", ",", "n"}], 
     "]"}], ";"}], "\n", "\[IndentingNewLine]", 
