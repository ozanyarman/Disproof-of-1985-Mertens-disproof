   RowBox[{
    RowBox[{"nMax", "=", 
     RowBox[{"Length", "[", "zeros", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"T", "=", 
     RowBox[{"zeros", "[", 
      RowBox[{"[", "nMax", "]"}], "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<Pre-calculating Ingham kernel weights...\>\"", "]"}], 
    ";"}], "\n", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Maintained", " ", "pure", " ", "high"}], "-", 
     RowBox[{"precision", " ", "evaluation", " ", "vectors"}]}], "*)"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"kKernel", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"1", "-", 
           RowBox[{
            RowBox[{"zeros", "[", 
             RowBox[{"[", "i", "]"}], "]"}], "/", "T"}]}], ")"}], "*", 
         RowBox[{"Cos", "[", 
          RowBox[{"Pi", "*", 
           RowBox[{
            RowBox[{"zeros", "[", 
             RowBox[{"[", "i", "]"}], "]"}], "/", "T"}]}], "]"}]}], "+", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"1", "/", "Pi"}], ")"}], "*", 
         RowBox[{"Sin", "[", 
          RowBox[{"Pi", "*", 
           RowBox[{
            RowBox[{"zeros", "[", 
             RowBox[{"[", "i", "]"}], "]"}], "/", "T"}]}], "]"}]}]}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "1", ",", "nMax"}], "}"}]}], "]"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", 
     "\"\<\\n=== 2. LOCATING THE HISTORICAL 1985 ALIGNMENT REGION ===\>\"", 
     "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"dominantIndices", "=", 
     RowBox[{"Ordering", "[", 
      RowBox[{"alphas", ",", 
       RowBox[{"-", "5"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Dominant zero frequencies: \>\"", ",", 
      RowBox[{"N", "[", 
       RowBox[{
        RowBox[{"zeros", "[", 
         RowBox[{"[", "dominantIndices", "]"}], "]"}], ",", "4"}], "]"}]}], 
     "]"}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<Scanning precision-safe phase intersections...\>\"", 
     "]"}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"FIX", " ", "1"}], ":", 
     RowBox[{
      RowBox[{
      "Swapped", " ", "out", " ", "machine", " ", "float", " ", "0.005", " ", 
       "for", " ", "exact", " ", "rational", " ", 
       RowBox[{"1", "/", "200"}], " ", "to", " ", "safeguard", " ", "250"}], 
      "-", 
      RowBox[{"digit", " ", "tracking"}]}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"stepSize", "=", 
     RowBox[{"1", "/", "200"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"searchRange", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"100000", "+", 
        RowBox[{"k", "*", "stepSize"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"k", ",", "0", ",", "50000"}], "}"}]}], "]"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"maxVal", "=", 
     RowBox[{"-", "Infinity"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"bestY", "=", "0"}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Dense", " ", "localized", " ", "scan", " ", "using", " ", "the", " ", 
     "first", " ", "50", " ", "zeros", " ", "to", " ", "keep", " ", "the", 
     " ", "initial", " ", "pass", " ", "rapid"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Do", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"y", "=", 
        RowBox[{"searchRange", "[", 
         RowBox[{"[", "k", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"currentVal", "=", 
        RowBox[{
         RowBox[{"-", "2"}], "*", 
         RowBox[{"Sum", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"kKernel", "[", 
             RowBox[{"[", "i", "]"}], "]"}], "*", 
            RowBox[{"alphas", "[", 
             RowBox[{"[", "i", "]"}], "]"}], "*", 
            RowBox[{"Cos", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"zeros", "[", 
                RowBox[{"[", "i", "]"}], "]"}], "*", "y"}], "-", 
              RowBox[{"psi", "[", 
               RowBox[{"[", "i", "]"}], "]"}]}], "]"}]}], ",", 
           RowBox[{"{", 
            RowBox[{"i", ",", "1", ",", "50"}], "}"}]}], "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"currentVal", ">", "maxVal"}], ",", 
         RowBox[{
          RowBox[{"maxVal", "=", "currentVal"}], ";", 
          RowBox[{"bestY", "=", "y"}], ";"}]}], "]"}], ";"}], ",", 
      RowBox[{"{", 
       RowBox[{"k", ",", "1", ",", 
        RowBox[{"Length", "[", "searchRange", "]"}]}], "}"}]}], "]"}], ";"}], 
   "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<\\nBest baseline candidate found at y = \>\"", ",", 
      RowBox[{"N", "[", 
       RowBox[{"bestY", ",", "15"}], "]"}]}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Baseline value (first 50 zeros): \>\"", ",", 
      RowBox[{"N", "[", 
       RowBox[{"maxVal", ",", "10"}], "]"}]}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"3.", " ", "High"}], "-", 
     RowBox[{
     "Precision", " ", "Hill", " ", "Climb", " ", "from", " ", "the", " ", 
      "Baseline", " ", "Point"}]}], "*)"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<\\n=== 3. RUNNING EXACT SPECTRUM CLIMBER ===\>\"", 
     "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{"UPGRADE", " ", "1"}], ":", 
      RowBox[{"Batch", "-", 
       RowBox[{"elevate", " ", "entire", " ", "100"}]}]}], ",", 
     RowBox[{
      RowBox[{"000", " ", "point", " ", "arrays", " ", "into", " ", "550"}], 
      "-", 
      RowBox[{"digit", " ", "containers"}]}]}], "*)"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", 
     "\"\<Pre-allocating 550-digit precision tracking containers for hill \
ascent...\>\"", "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"zerosHigh", "=", 
     RowBox[{"SetPrecision", "[", 
      RowBox[{"zeros", ",", "550"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"psiHigh", "=", 
     RowBox[{"SetPrecision", "[", 
      RowBox[{"psi", ",", "550"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"alphasHigh", "=", 
     RowBox[{"SetPrecision", "[", 
      RowBox[{"alphas", ",", "550"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"kKernelHigh", "=", 
     RowBox[{"SetPrecision", "[", 
      RowBox[{"kKernel", ",", "550"}], "]"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Pre", "-", 
     RowBox[{
     "multiply", " ", "tracking", " ", "vectors", " ", "to", " ", "maximize", 
      " ", "dot", " ", "product", " ", "execution", " ", "velocity"}]}], 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"preFactor1", "=", 
     RowBox[{"2", "*", "kKernelHigh", "*", "alphasHigh", "*", "zerosHigh"}]}],
     ";"}], "\n", 
   RowBox[{
    RowBox[{"preFactor2", "=", 
     RowBox[{"2", "*", "kKernelHigh", "*", "alphasHigh", "*", 
      RowBox[{"(", 
       RowBox[{"zerosHigh", "^", "2"}], ")"}]}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"UPGRADE", " ", "2"}], ":", 
     RowBox[{
      RowBox[{
      "Scale", " ", "the", " ", "isolated", " ", "coordinate", " ", "cleanly",
        " ", "up", " ", "to", " ", "the", " ", "550"}], "-", 
      RowBox[{"digit", " ", "environment"}]}]}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"currentY", "=", 
     RowBox[{"N", "[", 
      RowBox[{"bestY", ",", "550"}], "]"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", 
     "\"\<Executing Newton-Raphson spectrum maximization loop (30 \
iterations)...\>\"", "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Do", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Module", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
          "angles", ",", "cosArray", ",", "sinArray", ",", "deriv1", ",", 
           "deriv2", ",", "step"}], "}"}], ",", 
         RowBox[{
          RowBox[{"angles", "=", 
           RowBox[{
            RowBox[{"zerosHigh", "*", "currentY"}], "-", "psiHigh"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"cosArray", "=", 
           RowBox[{"Cos", "[", "angles", "]"}]}], ";", "\[IndentingNewLine]", 
          
          RowBox[{"sinArray", "=", 
           RowBox[{"Sin", "[", "angles", "]"}]}], ";", "\[IndentingNewLine]", 
          
          RowBox[{"(*", 
           RowBox[{"PERFORMANCE", " ", 
            RowBox[{"UPGRADE", ":", 
             RowBox[{
             "Explicit", " ", "Sum", " ", "replaced", " ", "with", " ", 
              "Vectorized", " ", "Dot", " ", "Product", " ", 
              RowBox[{"(", ".", ")"}]}]}]}], "*)"}], 
          RowBox[{"(*", 
           RowBox[{"First", " ", "Derivative", " ", 
            RowBox[{"(", 
             RowBox[{"f", "'"}], ")"}]}], "*)"}], 
          RowBox[{"deriv1", "=", 
           RowBox[{"preFactor1", ".", "sinArray"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{"Second", " ", "Derivative", " ", 
            RowBox[{"(", 
             RowBox[{"f", "''"}], ")"}]}], "*)"}], 
          RowBox[{"deriv2", "=", 
           RowBox[{"preFactor2", ".", "cosArray"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{
            RowBox[{"Execute", " ", "the", " ", "Newton"}], "-", 
            RowBox[{"Raphson", " ", "update", " ", "step"}]}], "*)"}], 
          RowBox[{"step", "=", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"Abs", "[", "deriv2", "]"}], ">", "0"}], ",", 
             RowBox[{"deriv1", "/", "deriv2"}], ",", "0"}], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{
            RowBox[{"FIX", " ", "3"}], ":", 
            RowBox[{
            "Replaced", " ", "machine", " ", "float", " ", "0.01", " ", 
             "threshold", " ", "with", " ", "exact", " ", "rational", " ", 
             RowBox[{"1", "/", "100"}]}]}], "*)"}], 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"Abs", "[", "step", "]"}], ">", 
             RowBox[{"1", "/", "100"}]}], ",", 
            RowBox[{"step", "=", 
             RowBox[{
              RowBox[{"Sign", "[", "step", "]"}], "*", 
              RowBox[{"(", 
               RowBox[{"1", "/", "100"}], ")"}]}]}]}], "]"}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"currentY", "=", 
           RowBox[{"currentY", "-", "step"}]}], ";"}]}], "]"}], ";"}], ",", 
      RowBox[{"{", 
       RowBox[{"iter", ",", "1", ",", "30"}], "}"}]}], "]"}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
     "Final", " ", "verification", " ", "evaluation", " ", "locked", " ", 
      "completely", " ", "at", " ", "550"}], "-", 
     RowBox[{"digit", " ", "arbitrary", " ", "precision"}]}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"finalPeak", "=", 
     RowBox[{
      RowBox[{"-", "2"}], "*", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"kKernelHigh", "*", "alphasHigh"}], ")"}], ".", 
       RowBox[{"Cos", "[", 
        RowBox[{
         RowBox[{"zerosHigh", "*", "currentY"}], "-", "psiHigh"}], 
        "]"}]}]}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<\\n=== FINAL VERIFICATION RESULTS ===\>\"", "]"}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Verified Peak Location y: \>\"", ",", 
      RowBox[{"NumberForm", "[", 
       RowBox[{"currentY", ",", "25"}], "]"}]}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Maximum verified value of hK(y): \>\"", ",", 
      RowBox[{"N", "[", 
       RowBox[{"finalPeak", ",", "10"}], "]"}]}], "]"}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"N", "[", "finalPeak", "]"}], ">", "1.0"}], ",", 
      RowBox[{"Print", "[", 
       RowBox[{"\"\<[checkmark] SUCCESS: The wave peak reaches \>\"", ",", 
        RowBox[{"N", "[", 
         RowBox[{"finalPeak", ",", "6"}], "]"}], ",", 
        "\"\<, breaking the 1.0 barrier! The Mertens Conjecture is \
false.\>\""}], "]"}], ",", 
      RowBox[{
      "Print", "[", 
       "\"\<\:2717 Wave peak did not clear 1.0. The search window must be \
shifted.\>\"", "]"}]}], "]"}], ";"}]}]}]], "Input",
