     "\"\<\\n=== 3. EXTRACTING TARGET COORDINATE VIA COSINE CREST INSPECTION \
===\>\"", "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"validRows", "=", 
     RowBox[{"Select", "[", 
      RowBox[{"reduced", ",", 
       RowBox[{
