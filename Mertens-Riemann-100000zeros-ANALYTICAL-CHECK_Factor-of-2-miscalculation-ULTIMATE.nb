      RowBox[{"000", " ", "arrays", " ", "into", " ", "550"}], "-", 
      RowBox[{"digit", " ", "memory", " ", "containers"}]}]}], "*)"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", 
     "\"\<Pre-allocating 550-digit precision tracking containers for wave \
interference...\>\"", "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"zerosHigh", "=", 
     RowBox[{"SetPrecision", "[", 
      RowBox[{"zeros", ",", "550"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"psiHigh", "=", 
     RowBox[{"SetPrecision", "[", 
      RowBox[{"psi", ",", "550"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"alphasHigh", "=", 
     RowBox[{"SetPrecision", "[", 
      RowBox[{"alphas", ",", "550"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"kKernelHigh", "=", 
     RowBox[{"SetPrecision", "[", 
      RowBox[{"kKernel", ",", "550"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Function", " ", "to", " ", "evaluate", " ", "hK", " ", "safely", " ", 
     "using", " ", "fast", " ", "vectorized", " ", "linear", " ", "algebra"}],
     "*)"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"evaluateHK", "[", "yVal_", "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"yHigh", ",", "sumVal"}], "}"}], ",", 
       RowBox[{
        RowBox[{"yHigh", "=", 
         RowBox[{"SetPrecision", "[", 
          RowBox[{"yVal", ",", "550"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{"Performance", " ", 
          RowBox[{"Optimization", ":", 
           RowBox[{
           "Vectorized", " ", "Total", " ", "operation", " ", "bypasses", " ",
             "slow", " ", "sequential", " ", "loop", " ", "processing"}]}]}], 
         "*)"}], 
        RowBox[{"sumVal", "=", 
         RowBox[{
          RowBox[{"-", "2"}], "*", 
          RowBox[{"Total", "[", 
           RowBox[{"kKernelHigh", "*", "alphasHigh", "*", 
            RowBox[{"Cos", "[", 
             RowBox[{
              RowBox[{"zerosHigh", "*", "yHigh"}], "-", "psiHigh"}], "]"}]}], 
           "]"}]}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"N", "[", 
         RowBox[{"sumVal", ",", "20"}], "]"}]}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", 
     "\"\<Sweeping local window around y0 to locate the true wave \
peak...\>\"", "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"results", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"y", ",", 
         RowBox[{"evaluateHK", "[", "y", "]"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"y", ",", "gridPoints"}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
    "Find", " ", "the", " ", "absolute", " ", "maximum", " ", "peak", " ", 
     "in", " ", "this", " ", "local", " ", "neighborhood"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"sortedResults", "=", 
     RowBox[{"SortBy", "[", 
      RowBox[{"results", ",", 
       RowBox[{
        RowBox[{"-", 
         RowBox[{"#", "[", 
          RowBox[{"[", "2", "]"}], "]"}]}], "&"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"bestMatch", "=", 
     RowBox[{"First", "[", "sortedResults", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"peakY", "=", 
     RowBox[{"bestMatch", "[", 
      RowBox[{"[", "1", "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"peakValue", "=", 
     RowBox[{"bestMatch", "[", 
      RowBox[{"[", "2", "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<\\n=== FINAL VERIFICATION RESULTS ===\>\"", "]"}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Highest localized peak found at y: \>\"", ",", 
      RowBox[{"ScientificForm", "[", 
       RowBox[{"N", "[", 
        RowBox[{"peakY", ",", "20"}], "]"}], "]"}]}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Maximum verified value of hK(y): \>\"", ",", 
      RowBox[{"InputForm", "[", "peakValue", "]"}]}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"N", "[", "peakValue", "]"}], ">", "1.0"}], ",", 
      RowBox[{"Print", "[", 
       RowBox[{
       "\"\<[checkmark] SUCCESS: The wave peak reaches \>\"", ",", 
        "peakValue", ",", 
        "\"\<, breaking the 1.0 barrier! The Mertens Conjecture is \
false.\>\""}], "]"}], ",", 
      RowBox[{
      "Print", "[", 
       "\"\<\:2717 Peak did not clear 1.0. This coordinate structure remains \
flatline below 1.0.\>\"", "]"}]}], "]"}], ";"}], "\[IndentingNewLine]", "\n", 
   
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
     "Safe", " ", "plot", " ", "block", " ", "wrapping", " ", "the", " ", 
      "high"}], "-", 
     RowBox[{
     "precision", " ", "results", " ", "in", " ", "standard", " ", "N", " ", 
      "to", " ", "bypass", " ", "frontend", " ", "rendering", " ", "lags"}]}],
     "*)"}], "\[IndentingNewLine]", 
   RowBox[{"ListLinePlot", "[", 
    RowBox[{
     RowBox[{"N", "[", 
      RowBox[{"results", "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", "2"}], "]"}], "]"}], "]"}], ",", 
     RowBox[{"PlotLabel", "->", "\"\<Local Wave Interference Near y0\>\""}], 
     ",", 
     RowBox[{"AxesLabel", "->", 
      RowBox[{"{", 
       RowBox[{"\"\<Sample Index\>\"", ",", "\"\<hK(y)\>\""}], "}"}]}], ",", 
     RowBox[{"GridLines", "->", "Automatic"}], ",", 
     RowBox[{"PlotRange", "->", "All"}]}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.989892874657387*^9, 3.98989287467815*^9}, 
