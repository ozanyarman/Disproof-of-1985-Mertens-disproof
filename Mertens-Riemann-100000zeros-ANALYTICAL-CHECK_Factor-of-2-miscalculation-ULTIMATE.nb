                RowBox[{
                 RowBox[{"row", "[", 
                  RowBox[{"[", 
                   RowBox[{"n", "+", "1"}], "]"}], "]"}], "/", 
                 RowBox[{"Floor", "[", 
                  RowBox[{
                   RowBox[{"2", "^", "v"}], "*", 
                   RowBox[{"n", "^", "4"}]}], "]"}]}], ",", "0"}], "]"}]}], 
             ";", "\[IndentingNewLine]", 
             RowBox[{"candidateY0", "=", 
              RowBox[{"N", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{"Abs", "[", "c1", "]"}], "/", "1024"}], ",", "550"}],
                "]"}]}], ";", "\[IndentingNewLine]", 
             RowBox[{"(*", 
