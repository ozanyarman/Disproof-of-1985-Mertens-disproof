               RowBox[{"[", 
                RowBox[{"n", "+", "2"}], "]"}], "]"}]}], ";", 
             "\[IndentingNewLine]", 
             RowBox[{"c2", "=", 
              RowBox[{"If", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{"Floor", "[", 
                  RowBox[{
                   RowBox[{"2", "^", "v"}], "*", 
                   RowBox[{"n", "^", "4"}]}], "]"}], ">", "0"}], ",", 
                RowBox[{
                 RowBox[{"row", "[", 
                  RowBox[{"[", 
                   RowBox[{"n", "+", "1"}], "]"}], "]"}], "/", 
                 RowBox[{"Floor", "[", 
                  RowBox[{
                   RowBox[{"2", "^", "v"}], "*", 
                   RowBox[{"n", "^", "4"}]}], "]"}]}], ",", "0"}], "]"}]}], 
             ";", "\[IndentingNewLine]", 
             RowBox[{"candidateY0", "=", 
              RowBox[{"N", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{"Abs", "[", "c1", "]"}], "/", "1024"}], ",", "550"}],
                "]"}]}], ";", "\[IndentingNewLine]", 
             RowBox[{"(*", 
              RowBox[{
              "Scan", " ", "local", " ", "coordinates", " ", "using", " ", 
               "fast", " ", "dot", " ", "products", " ", "to", " ", "look", 
               " ", "for", " ", "the", " ", "highest", " ", "peak"}], "*)"}], 
             
             RowBox[{"maxLocalSum", "=", 
              RowBox[{"Max", "[", 
               RowBox[{"Table", "[", 
                RowBox[{
                 RowBox[{
                  RowBox[{"-", "2"}], "*", 
                  RowBox[{"preFact", ".", 
                   RowBox[{"Cos", "[", 
                    RowBox[{
                    RowBox[{"subZeros", "*", 
                    RowBox[{"(", 
                    RowBox[{"candidateY0", "+", 
                    RowBox[{"k", "*", 
                    RowBox[{"2", "/", "100"}]}]}], ")"}]}], "-", "subPsi"}], 
                    "]"}]}]}], ",", 
                 RowBox[{"{", 
                  RowBox[{"k", ",", 
                   RowBox[{"-", "10"}], ",", "10"}], "}"}]}], "]"}], "]"}]}], 
             ";", "\[IndentingNewLine]", 
             RowBox[{"{", 
              RowBox[{"row", ",", "candidateY0", ",", "maxLocalSum", ",", 
               RowBox[{"Abs", "[", "c2", "]"}]}], "}"}]}]}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"row", ",", "validRows"}], "}"}]}], "]"}]}], ";"}]}], 
     "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
