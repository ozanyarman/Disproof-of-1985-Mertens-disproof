        "\"\<, breaking the -1.0 barrier!\>\""}], "]"}], ",", 
      RowBox[{
      "Print", "[", 
       "\"\<\:2717 Wave trough did not drop below -1.0. This configuration \
remains bounded above -1.0.\>\"", "]"}]}], "]"}], ";"}]}]}]], "Input",
