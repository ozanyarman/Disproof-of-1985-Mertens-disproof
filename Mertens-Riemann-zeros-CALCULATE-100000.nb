Notebook[{

Cell[CellGroupData[{
Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"ClearAll", "[", "\"\<Global`*\>\"", "]"}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"numZeros", "=", "100000"}], ";", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"test", " ", "with", " ", "3"}], ",", 
     RowBox[{"then", " ", "2000"}], ",", 
     RowBox[{"then", " ", "scale", " ", "up"}]}], "*)"}], 
   RowBox[{"prec", "=", "250"}], ";"}], "\n", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"1.", " ", "Compute", " ", "the", " ", 
     RowBox[{"zeros", "--"}], " ", "this", " ", "list", " ", "stays", " ", 
     "sacred"}], ",", 
    RowBox[{"never", " ", "reassigned"}]}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"gammas", "=", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"Im", "[", 
       RowBox[{"N", "[", 
        RowBox[{
         RowBox[{"ZetaZero", "[", "n", "]"}], ",", "prec"}], "]"}], "]"}], 
      ",", 
      RowBox[{"{", 
       RowBox[{"n", ",", "1", ",", "numZeros"}], "}"}]}], "]"}]}], ";"}], 
  "\n", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"Guard", " ", "against", " ", "a", " ", "non"}], "-", "list"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"If", "[", 
   RowBox[{
    RowBox[{"!", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"ListQ", "[", "gammas", "]"}], "&&", 
       RowBox[{
        RowBox[{"Length", "[", "gammas", "]"}], "==", "numZeros"}]}], ")"}]}],
     ",", 
    RowBox[{
     RowBox[{"Print", "[", 
      RowBox[{"\"\<FATAL: gammas is not a list -> \>\"", ",", 
       RowBox[{"Head", "[", "gammas", "]"}]}], "]"}], ";", 
     RowBox[{"Abort", "[", "]"}]}]}], "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Print", "[", 
   RowBox[{"\"\<Precision check : \>\"", ",", 
    RowBox[{"Precision", "[", 
     RowBox[{"gammas", "[", 
      RowBox[{"[", "1", "]"}], "]"}], "]"}]}], "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"Print", "[", 
    RowBox[{"\"\<First zero      : \>\"", ",", 
     RowBox[{"N", "[", 
      RowBox[{
       RowBox[{"gammas", "[", 
        RowBox[{"[", "1", "]"}], "]"}], ",", "12"}], "]"}]}], "]"}], ";"}], 
  "\n", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"2.", " ", "Clean", " ", 
     RowBox[{"formatter", ":", 
      RowBox[{"250", " ", "significant", " ", "digits"}]}]}], ",", 
    RowBox[{"no", " ", "backtick"}], ",", 
    RowBox[{"no", " ", "marker"}]}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"fmt", "[", "x_", "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"d", ",", "e"}], "}"}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"{", 
         RowBox[{"d", ",", "e"}], "}"}], "=", 
        RowBox[{"RealDigits", "[", 
         RowBox[{"x", ",", "10", ",", "prec"}], "]"}]}], ";", 
       RowBox[{"(*", 
        RowBox[{"prec", " ", "significant", " ", "digits"}], "*)"}], 
       RowBox[{"StringInsert", "[", 
        RowBox[{
         RowBox[{"StringJoin", "[", 
          RowBox[{"ToString", "/@", "d"}], "]"}], ",", "\"\<.\>\"", ",", 
         RowBox[{"e", "+", "1"}]}], "]"}]}]}], "]"}]}], ";"}], "\n", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"2", 
    RowBox[{"b", ".", "TEST"}], " ", "the", " ", "formatter", " ", "on", " ", 
    "ONE", " ", "element", " ", "before", " ", "mapping", " ", "everything"}],
    "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Print", "[", 
   RowBox[{"\"\<fmt test        : \>\"", ",", 
    RowBox[{"StringTake", "[", 
     RowBox[{
      RowBox[{"fmt", "[", 
       RowBox[{"gammas", "[", 
        RowBox[{"[", "1", "]"}], "]"}], "]"}], ",", "20"}], "]"}], ",", 
    "\"\< ...\>\""}], "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"If", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Head", "[", 
       RowBox[{"fmt", "[", 
        RowBox[{"gammas", "[", 
         RowBox[{"[", "1", "]"}], "]"}], "]"}], "]"}], "=!=", "String"}], ",", 
     RowBox[{
      RowBox[{
      "Print", "[", "\"\<FATAL: fmt did not return a string\>\"", "]"}], ";", 
      
      RowBox[{"Abort", "[", "]"}]}]}], "]"}], ";"}], "\n", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"3.", " ", "Build", " ", "the", " ", "comma"}], "-", 
    RowBox[{"separated", " ", "text"}]}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"rawText", "=", 
    RowBox[{
     RowBox[{"StringRiffle", "[", 
      RowBox[{
       RowBox[{"fmt", "/@", "gammas"}], ",", "\"\<,\>\""}], "]"}], "<>", 
     "\"\<,\>\""}]}], ";"}], "\n", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"4.", " ", "Write", " ", "plain", " ", "text"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"txtPath", "=", 
   RowBox[{"FileNameJoin", "[", 
    RowBox[{"{", 
     RowBox[{
     "$HomeDirectory", ",", "\"\<Desktop\>\"", ",", "\"\<gammas250.txt\>\""}],
      "}"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"str", "=", 
   RowBox[{"OpenWrite", "[", "txtPath", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"WriteString", "[", 
   RowBox[{"str", ",", "rawText"}], "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"Close", "[", "str", "]"}], ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"Print", "[", 
   RowBox[{"\"\<Done -> \>\"", ",", "txtPath"}], "]"}], ";"}]}], "Input",
 CellChangeTimes->{{3.9906535154725733`*^9, 3.990653535015527*^9}},
 CellLabel->"In[49]:=",ExpressionUUID->"be1736c3-b05f-49cf-a9dc-2cac7bd2af43"],

